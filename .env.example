# ── Supabase (requerido) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Admin ─────────────────────────────────────────────────────────────────────
# ADMIN_SECRET: token que validan las API routes (nunca usar NEXT_PUBLIC_ADMIN_SECRET)
# ADMIN_EMAIL / ADMIN_PASSWORD: credenciales del panel — solo conocidas por el servidor
ADMIN_SECRET=cambia-esto-por-un-string-largo-aleatorio
ADMIN_EMAIL=tu-email-admin@dominio.com
ADMIN_PASSWORD=cambia-esto-por-password-segura

# ── Email (Resend — https://resend.com) ───────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Sigma Research <noreply@sigma-research.io>
EMAIL_ADMIN_TO=soporte@sigma-research.io
NEXT_PUBLIC_APP_URL=https://sigma-research.io

# ── APIs externas para Macro Calendar (opcionales — fallback a mock si ausentes) ─
# Federal Reserve Economic Data — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# CoinMarketCal — https://coinmarketcal.com/en/api
COINMARKETCAL_API_KEY=

# VPS del motor SIGMA (URL pública e interna)
VPS_URL=https://motor.squantdesk.com
VPS_INTERNAL=http://127.0.0.1:8080

# Binance (para Terminal y HUD)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# CMF Chile — Tasa de Interés Promedio (TIP) — https://api.cmfchile.cl
CMF_API_KEY=

# EIA — inventarios petróleo/gas para Macro Calendar — https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# ── Cron jobs (requerido para /api/cron/*) ───────────────────────────────────
# Sin esto todos los endpoints de cron fallan la validación de seguridad
CRON_SECRET=cambia-esto-por-un-string-largo-aleatorio

# ── Motor en Vivo (/motor-en-vivo) ───────────────────────────────────────────
ENGINE_MONITOR_PASSWORD=cambia-esto-por-password-del-motor
ENGINE_MONITOR_SECRET=cambia-esto-por-un-string-largo-aleatorio

# Contraseña del dashboard web del motor en el VPS (puerto 8080)
VPS_MOTOR_PASS=0808
