_ja30 = '"tt_total":'+str.tostring(tt_total)+',"tt_wins":'+str.tostring(tt_wins)+',"tt_losses":'+str.tostring(tt_losses)+',"tt_wr":'+_j4(tt_wr)+',"tt_pnl":'+_j2(tt_pnl_disp)+',"tt_expect":'+_j4(tt_expectancy)+',"tt_pf":'+_j2(tt_pf)+','
