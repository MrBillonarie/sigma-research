// [SIGMA-HEADER-START]
// ╔══════════════════════════════════════════════════════════╗
// ║  SIGMA TERMINAL v13  —  Auto-generado desde VPS         ║
// ║  Actualizado : 09/06/2026  11:30 hrs (Chile)             ║
// ║  Modelos     : 20 activos                                ║
// ║  Top modelos : XAU 1h:REG A+ +205%  LTC 1h:WIL A+ +130%  ║
// ╚══════════════════════════════════════════════════════════╝
// [SIGMA-HEADER-END]
//@version=6

indicator("SIGMA TERMINAL v13.0", overlay=true, max_lines_count=500, max_boxes_count=200, max_labels_count=200, max_bars_back=500)

// INPUTS GLOBALES
show_levels         = input.bool(true,  "Niveles SL/TP en chart",        group="Display")
show_signals        = input.bool(true,  "Señales visuales en chart",      group="Display")
show_ob             = input.bool(true,  "Order Blocks",                   group="Display")
show_fvg            = input.bool(true,  "Fair Value Gaps",                group="Display")
show_avwap          = input.bool(true,  "AVWAP semanal",                  group="Display")
show_ema50          = input.bool(true,  "EMA 50",                         group="Display")
show_ema200         = input.bool(true,  "EMA 200",                        group="Display")
show_swings         = input.bool(true,  "Swing High/Low",                 group="Display")
show_quality_levels = input.bool(true,  "Niveles por calidad E/X/W",      group="Display")

col_long    = input.color(color.lime,   "Long",    group="Colores")
col_short   = input.color(color.red,    "Short",   group="Colores")
col_elite   = input.color(color.aqua,   "Elite",   group="Colores")
col_warn    = input.color(color.orange, "Warning", group="Colores")
col_neutral = input.color(color.gray,   "Neutral", group="Colores")

market_type     = input.string("AUTO","Tipo de mercado", options=["AUTO","CRYPTO","FOREX","COMMODITY","EQUITY"], group="Mercado")
session_a_start = input.int(8,  "Sesión A inicio UTC", minval=0, maxval=23, group="Mercado")
session_a_end   = input.int(12, "Sesión A fin UTC",    minval=1, maxval=24, group="Mercado")
session_b_start = input.int(13, "Sesión B inicio UTC", minval=0, maxval=23, group="Mercado")
session_b_end   = input.int(20, "Sesión B fin UTC",    minval=1, maxval=24, group="Mercado")
market_schedule = input.string("CRYPTO_24_7","Horario mercado", options=["CRYPTO_24_7","FOREX_5D","EQUITY_5D","FUTURES_5D"], group="Mercado")

setup_weight    = input.float(0.55,"Setup weight", minval=0.3, maxval=0.7, step=0.05, group="Score")
timing_weight   = 1.0 - setup_weight
watch_thr       = input.int(40,"WATCH umbral mínimo",   minval=20, maxval=70, step=5, group="Score")

atr_sl_mult = input.float(1.5,"ATR mult SL", minval=0.5, maxval=4.0, step=0.25, group="SL/TP")
atr_tp_mult = input.float(2.0,"ATR mult TP", minval=1.0, maxval=8.0, step=0.25, group="SL/TP")

q_elite_sl = input.float(1.3,"ELITE SL x ATR",   minval=0.5, maxval=3.0, step=0.1, group="Calidades")
q_elite_tp = input.float(2.5,"ELITE TP x ATR",   minval=1.0, maxval=6.0, step=0.1, group="Calidades")
q_exec_sl  = input.float(1.5,"EXECUTE SL x ATR", minval=0.5, maxval=3.0, step=0.1, group="Calidades")
q_exec_tp  = input.float(2.0,"EXECUTE TP x ATR", minval=1.0, maxval=6.0, step=0.1, group="Calidades")
q_watch_sl = input.float(1.8,"WATCH SL x ATR",   minval=0.5, maxval=3.0, step=0.1, group="Calidades")
q_watch_tp = input.float(1.4,"WATCH TP x ATR",   minval=1.0, maxval=6.0, step=0.1, group="Calidades")


capital          = input.float(1000.0,"Capital ($)",           minval=10,  step=100,  group="Riesgo")
risk_pct         = input.float(0.5,  "Riesgo base % Fase 0",  minval=0.1, maxval=5.0, step=0.1, group="Riesgo")
use_kelly        = input.bool(false, "Kelly Criterion",                               group="Riesgo")
kelly_min_trades = input.int(8,  "Kelly min trades",  minval=8,  maxval=50,  group="Riesgo")
kelly_lookback   = input.int(50, "Kelly ventana",     minval=10, maxval=200, step=10, group="Riesgo")
kelly_fraction   = input.float(0.25,"Kelly fracción", minval=0.1, maxval=1.0, step=0.05, group="Riesgo")
use_dd_scalar    = input.bool(true,"Drawdown Scalar",                                 group="Riesgo")
dd_losses_l1     = input.int(2,"DD nivel 1 → 75%", minval=1, maxval=10, group="Riesgo")
dd_losses_l2     = input.int(4,"DD nivel 2 → 50%", minval=2, maxval=15, group="Riesgo")
dd_losses_l3     = input.int(6,"DD nivel 3 → 25%", minval=3, maxval=20, group="Riesgo")
min_ev           = input.float(0.10,"EV mínimo", minval=0.0, maxval=1.0, step=0.05, group="Riesgo")

hard_min_conf_trend    = input.int(65,   "TREND confluencia mín",    minval=50, maxval=95, step=5,  group="Hard Filters")
hard_min_conf_range    = input.int(60,   "RANGE confluencia mín",    minval=50, maxval=95, step=5,  group="Hard Filters")
hard_min_rr            = input.float(1.5,"RR mínimo",                minval=1.0, maxval=4.0, step=0.1, group="Hard Filters")
hard_max_consec_losses = input.int(2,    "Max losses consec",        minval=1,  maxval=5,  group="Hard Filters")
hard_cooldown_bars     = input.int(8,    "Cooldown post-loss velas", minval=2,  maxval=50, group="Hard Filters")
hard_min_ev_net        = input.float(0.05,"EV neto mínimo",          minval=0.0, maxval=1.0, step=0.05, group="Hard Filters")
hard_require_htf       = input.bool(true,"Requiere HTF aligned",                          group="Hard Filters")
hard_block_volatil     = input.bool(true,"Bloquear régimen volátil",                      group="Hard Filters")
hard_vol_pctl_max      = input.int(85,   "Vol percentil max",        minval=70, maxval=95, group="Hard Filters")

auto_block_enable = input.bool(true, "Auto-bloqueo activo",   group="Auto-bloqueo")
auto_block_window = input.int(20,    "Ventana rolling",        minval=10, maxval=100, group="Auto-bloqueo")
auto_block_min_wr = input.float(0.40,"WR mínimo",             minval=0.30, maxval=0.60, step=0.05, group="Auto-bloqueo")
auto_block_min_pf = input.float(1.0, "PF mínimo",             minval=0.8, maxval=2.0, step=0.1, group="Auto-bloqueo")

hurst_trend_thr   = input.float(0.55,"Hurst umbral TREND", minval=0.50, maxval=0.65, step=0.01, group="Dual-mode")
hurst_range_thr   = input.float(0.50,"Hurst umbral RANGE", minval=0.40, maxval=0.55, step=0.01, group="Dual-mode")
adx_trend_thr     = input.int(25,"ADX mín TREND", minval=15, maxval=40, group="Dual-mode")
adx_range_thr     = input.int(20,"ADX max RANGE", minval=15, maxval=30, group="Dual-mode")

use_power_hour      = input.bool(false,"Solo Power Hour",           group="Filtros temporales")
ph_start_hour       = input.int(13,   "Power Hour inicio UTC",     minval=0, maxval=23, group="Filtros temporales")
ph_end_hour         = input.int(15,   "Power Hour fin UTC",        minval=1, maxval=24, group="Filtros temporales")
exclude_sunday      = input.bool(true,"Excluir domingo",           group="Filtros temporales")
exclude_monday_pre  = input.bool(true,"Excluir lunes pre-13h UTC", group="Filtros temporales")
exclude_news_window = input.bool(true,"Excluir FOMC/NFP",          group="Filtros temporales")

use_be_after_tp1 = input.bool(true,"Mover SL a BE tras TP1",  group="Trade management")
tt_bars_max_inp  = input.int(16,  "Timeout trade velas",       minval=5, maxval=100, group="Trade management")

ultra_strict_mode   = input.bool(false,"ULTRA STRICT solo ELITE",    group="Ultra Strict")
ultra_min_confluence= input.int(75,   "Confluencia mín",             minval=70, maxval=95, step=5, group="Ultra Strict")
ultra_min_rr        = input.float(2.5,"RR mínimo",                   minval=2.0, maxval=4.0, step=0.1, group="Ultra Strict")
ultra_min_ev_net    = input.float(0.15,"EV neto mínimo",             minval=0.05, maxval=0.5, step=0.05, group="Ultra Strict")
ultra_require_dual  = input.bool(true,"Requiere DUAL-MODE válido",   group="Ultra Strict")
ultra_max_vol_pctl  = input.int(70,   "Vol percentil max",           minval=50, maxval=85, group="Ultra Strict")

p_win_bull        = input.float(0.52,"P(win) alcista",        minval=0.40, maxval=0.75, step=0.01, group="Avanzado")
p_win_bear        = input.float(0.48,"P(win) bajista",        minval=0.35, maxval=0.65, step=0.01, group="Avanzado")
ob_lookback       = input.int(10,   "OB lookback",            minval=3,  maxval=50,  group="Avanzado")
fvg_min_size      = input.float(0.05,"FVG tamaño mín %",     minval=0.01, maxval=1.0, step=0.01, group="Avanzado")
swing_len         = input.int(10,   "Swing length",           minval=5,  maxval=30,  group="Avanzado")
ofi_lookback_base = input.int(20,   "OFI lookback base",      minval=5,  maxval=100, group="Avanzado")
ofi_threshold     = input.float(0.6,"OFI umbral señal",       minval=0.3, maxval=0.9, step=0.05, group="Avanzado")
regime_lookback   = input.int(50,   "Régimen ventana",        minval=20, maxval=200, group="Avanzado")
vol_target_annual = input.float(0.15,"Vol Target anual",      minval=0.05, maxval=0.50, step=0.01, group="Avanzado")
wf_window         = input.int(100,  "Walk-forward OOS",       minval=50, maxval=500, group="Avanzado")
wf_min_trades     = input.int(10,   "WF min trades",          minval=5,  maxval=30,  group="Avanzado")
n_rules_tested    = input.int(15,   "N reglas Bonferroni",    minval=1,  maxval=50,  group="Avanzado")
corr_lookback     = input.int(20,   "Correlación ventana",    minval=10, maxval=60,  group="Avanzado")
corr_warn_thr     = input.float(0.7,"Correlación umbral",     minval=0.4, maxval=0.95, step=0.05, group="Avanzado")
slippage_bps      = input.float(5.0,"Slippage bps",           minval=0.0, maxval=50.0, step=0.5, group="Avanzado")
max_vol_part      = input.float(0.10,"Max % volumen mercado", minval=0.01, maxval=0.30, step=0.01, group="Avanzado")
gap_protect_bars  = input.int(2,    "Bloquear N velas post-gap", minval=0, maxval=20, group="Avanzado")
alert_cooldown    = input.int(3,    "Cooldown alertas velas",    minval=0, maxval=50, group="Avanzado")
show_honest_warn  = input.bool(true,"Warnings honestidad estadística", group="Avanzado")

data_export          = input.bool(true, "Exportar JSON a Make.com",     group="Export")
data_export_periodic = input.bool(false,"Export periódico cada N velas",group="Export")
data_export_every_n  = input.int(20,   "N velas export periódico",      minval=5, maxval=100, group="Export")
tg_chat_id           = input.string("6085164298","Telegram Chat ID",    group="Export")

// MÓDULO A — CONTEXTO DE MERCADO

// A1 — DETECCIÓN DE ACTIVO Y TIMEFRAME
_type_raw = syminfo.type
_ticker   = syminfo.ticker
is_crypto    = market_type=="AUTO"?(str.contains(_ticker,"USDT") or str.contains(_ticker,"BTC") or str.contains(_ticker,"ETH") or _type_raw=="crypto"):market_type=="CRYPTO"
is_forex     = market_type=="AUTO"?_type_raw=="forex":market_type=="FOREX"
is_commodity = market_type=="AUTO"?(_type_raw=="futures" or str.contains(_ticker,"XAU") or str.contains(_ticker,"XAG")):market_type=="COMMODITY"
is_equity    = market_type=="AUTO"?(_type_raw=="stock" or _type_raw=="fund"):market_type=="EQUITY"
asset_type_txt = is_crypto?"CRYPTO":is_forex?"FOREX":is_commodity?"COMMODITY":is_equity?"EQUITY":"UNIVERSAL"

tf_mins  = timeframe.in_seconds(timeframe.period)/60
tf_label = tf_mins<=1?"1M":tf_mins<=3?"3M":tf_mins<=5?"5M":tf_mins<=15?"15M":tf_mins<=30?"30M":tf_mins<=60?"1H":tf_mins<=240?"4H":tf_mins<=1440?"D":"W"

tf_vol_ma_len  = math.max(5,  math.min(300,math.round(300.0 /math.max(tf_mins,1.0))))
tf_vol_ma90_l  = math.max(20, math.min(500,math.round(1350.0/math.max(tf_mins,1.0))))
tf_mom_lb      = math.max(2,  math.min(50, math.round(45.0  /math.max(tf_mins,1.0))))
tf_mom_sens    = math.max(1,  math.min(50, math.round(150.0 /math.max(tf_mins,1.0))))
tf_speed_lb    = math.max(2,  math.min(100,math.round(75.0  /math.max(tf_mins,1.0))))
tf_speed_ma    = math.max(5,  math.min(300,math.round(300.0 /math.max(tf_mins,1.0))))
tf_mom_1h_sens = tf_mins>=60 ?1:math.max(1,math.round(5.0*15.0/math.max(tf_mins,1.0)))
tf_mom_4h_sens = tf_mins>=240?1:math.max(1,math.round(3.0*15.0/math.max(tf_mins,1.0)))
ofi_lookback   = math.max(5,math.min(100,math.round(ofi_lookback_base*15.0/math.max(tf_mins,1.0))))

bars_per_day  = market_schedule=="CRYPTO_24_7"?96.0:market_schedule=="FOREX_5D"?64.0:market_schedule=="EQUITY_5D"?26.0:48.0
bars_per_year = bars_per_day*(15.0/math.max(tf_mins,1.0))*(market_schedule=="CRYPTO_24_7"?365.0:252.0)

// A2 — INDICADORES BASE
atr     = ta.atr(14)
atr14   = atr
atr50   = ta.atr(50)
atr_ma  = ta.sma(atr,50)
atr_ratio    = atr/math.max(atr_ma,0.0001)
atr_ratio_r  = atr14/math.max(atr50,0.0001)
vol_percentile = ta.percentrank(atr14,100)

ema20  = ta.ema(close,20)
ema50  = ta.ema(close,50)
ema200 = ta.ema(close,200)

bb_basis = ta.sma(close,20)
bb_dev   = ta.stdev(close,20)
bb_upper = bb_basis+bb_dev*2
bb_lower = bb_basis-bb_dev*2
bb_width = (bb_dev*2)/math.max(bb_basis,0.0001)*100

[macd_line,signal_line,macd_hist] = ta.macd(close,12,26,9)
rsi     = ta.rsi(close,14)
stoch_k = ta.sma(ta.stoch(close,high,low,14),3)
stoch_d = ta.sma(stoch_k,3)

vol_ma   = ta.sma(volume,tf_vol_ma_len)
vol_ma90 = ta.sma(volume,tf_vol_ma90_l)
volume_ok = volume>vol_ma*1.5

vol_expanding  = atr_ratio>1.2
vol_compressing= atr_ratio<0.85

kc_basis = ta.ema(close,20)
kc_upper = kc_basis+atr*1.5
kc_lower = kc_basis-atr*1.5
bb_squeeze = bb_upper<kc_upper and bb_lower>kc_lower
is_spike   = (high-low)>atr*2.0

body       = math.abs(close-open)
candle_rng = high-low
upper_wick = high-math.max(close,open)
lower_wick = math.min(close,open)-low

is_engulfing_bull = close>open and close[1]<open[1] and close>open[1] and open<close[1]
is_engulfing_bear = close<open and close[1]>open[1] and close<open[1] and open>close[1]
is_doji  = body<candle_rng*0.1 and candle_rng>atr*0.5
is_hammer= lower_wick>body*2.0 and upper_wick<body*0.5 and candle_rng>atr*0.3
is_shooter=upper_wick>body*2.0 and lower_wick<body*0.5 and candle_rng>atr*0.3
is_inside_bar=high<high[1] and low>low[1]
candle_pattern_txt=is_engulfing_bull?"ENGULFING BULL":is_engulfing_bear?"ENGULFING BEAR":is_hammer?"HAMMER":is_shooter?"SHOOT STAR":is_inside_bar?"INSIDE BAR":is_doji?"DOJI":body>candle_rng*0.9 and close>open?"MARUBOZU BULL":body>candle_rng*0.9?"MARUBOZU BEAR":"NORMAL"

// RSI semanal — idéntico al VPS (rsi14 en timeframe semanal, forward-filled)
rsi_w = request.security(syminfo.tickerid,"W",ta.rsi(close,14),lookahead=barmerge.lookahead_off)

// vol_ma fijo 20 periodos para señales del modelo (igual que VPS: v.rolling(20).mean())
vol_ma_20 = ta.sma(volume,20)

[ema50_1h,ema200_1h] = request.security(syminfo.tickerid,"60", [ta.ema(close,50),ta.ema(close,200)],lookahead=barmerge.lookahead_off)
[ema50_4h,ema200_4h] = request.security(syminfo.tickerid,"240",[ta.ema(close,50),ta.ema(close,200)],lookahead=barmerge.lookahead_off)
[ema50_d, ema200_d]  = request.security(syminfo.tickerid,"D",  [ta.ema(close,50),ta.ema(close,200)],lookahead=barmerge.lookahead_off)

htf_long  = ema50_1h>ema200_1h
htf_short = ema50_1h<ema200_1h
htf4_long = ema50_4h>ema200_4h
htfd_long = ema50_d >ema200_d

htf_aligned_long  = htf_long  and htf4_long
htf_aligned_short = htf_short and not htf4_long
htf_aligned       = htf_aligned_long or htf_aligned_short

bull = ema50>ema200
bear = ema50<ema200
trend_power  = math.abs(ema50-ema200)
strong_trend = trend_power>atr*0.5

tf3_bull = bull and htf_long  and htf4_long
tf3_bear = bear and htf_short and not htf4_long
tf4_bull = tf3_bull and htfd_long
tf4_bear = tf3_bear and not htfd_long

// A3 — RÉGIMEN (unificado)
ret     = (close-close[1])/close[1]
ret_ma  = ta.sma(ret,regime_lookback)
ret_sq  = math.pow(ret-ret_ma,2)
ret_std = math.sqrt(math.max(ta.sma(ret_sq,regime_lookback),0.0))

range_n  = ta.highest(close,regime_lookback)-ta.lowest(close,regime_lookback)
range_n2 = ta.highest(close,regime_lookback/2)-ta.lowest(close,regime_lookback/2)
hurst    = range_n2>0?math.log(range_n/math.max(range_n2,0.0001))/math.log(2.0):0.5

price_slope      = ta.linreg(close,regime_lookback,0)-ta.linreg(close,regime_lookback,regime_lookback-1)
price_slope_norm = price_slope/math.max(atr50*regime_lookback,0.0001)

f_adx(int len)=>
    up=ta.change(high)
    dn=-ta.change(low)
    pDM=(up>dn and up>0)?up:0.0
    mDM=(dn>up and dn>0)?dn:0.0
    tr_=ta.rma(ta.tr,len)
    plus=100*ta.rma(pDM,len)/math.max(tr_,0.0001)
    minus=100*ta.rma(mDM,len)/math.max(tr_,0.0001)
    dx=100*math.abs(plus-minus)/math.max(plus+minus,0.0001)
    ta.rma(dx,len)
adx14 = f_adx(14)

bb_width_pctl = ta.percentrank(bb_width,100)

is_high_vol    = vol_percentile>hard_vol_pctl_max
is_strong_trend= hurst>hurst_trend_thr and adx14>adx_trend_thr and not is_high_vol
is_weak_range  = hurst<hurst_range_thr and adx14<adx_range_thr and not is_high_vol

regime_trend_up   = is_strong_trend and bull and close>ema50
regime_trend_down = is_strong_trend and bear and close<ema50
regime_ranging    = is_weak_range   and not is_high_vol
regime_volatile   = is_high_vol

regime_txt   = regime_trend_up?"TREND BULL":regime_trend_down?"TREND BEAR":regime_ranging?"RANGO":regime_volatile?"VOLATIL":"TRANSICION"
regime_color = regime_trend_up?col_long:regime_trend_down?col_short:regime_ranging?color.yellow:regime_volatile?col_warn:col_neutral

regime_sl_mult  = regime_volatile?1.25:regime_ranging?0.9:1.0
regime_tp_mult  = regime_ranging?0.8:regime_volatile?1.15:1.0
regime_ev_mult  = regime_trend_up or regime_trend_down?1.0:regime_ranging?0.9:regime_volatile?0.7:0.85
min_ev_regime   = min_ev/math.max(regime_ev_mult,0.1)

dual_mode_txt = regime_trend_up?"TREND_UP":regime_trend_down?"TREND_DOWN":regime_ranging?"RANGE":regime_volatile?"VOLATIL":"TRANSITION"
regime_detail = "H="+str.tostring(hurst,"#.##")+"  ADX="+str.tostring(adx14,"#")+"  slope="+str.tostring(price_slope_norm,"#.##")+"  vol%="+str.tostring(math.round(vol_percentile))

// A4 — OFI
body_ratio = math.abs(close-open)/math.max(high-low,0.0001)
buy_vol_sum  = math.sum(volume*(close>open?body_ratio:0.0), ofi_lookback_base)
sell_vol_sum = math.sum(volume*(close<open?body_ratio:0.0), ofi_lookback_base)
ofi_raw      = (buy_vol_sum+sell_vol_sum)>0?(buy_vol_sum-sell_vol_sum)/(buy_vol_sum+sell_vol_sum):0.0
ofi          = ta.ema(ofi_raw,3)
ofi_accel    = ofi - ta.ema(ofi_raw[3],3)
ofi_bull     = ofi> ofi_threshold
ofi_bear     = ofi<-ofi_threshold
ofi_neutral  = not ofi_bull and not ofi_bear

price_making_high = close>=ta.highest(close,ofi_lookback_base)
price_making_low  = close<=ta.lowest(close, ofi_lookback_base)
ofi_div_bear = price_making_high and ofi<ofi[ofi_lookback_base]
ofi_div_bull = price_making_low  and ofi>ofi[ofi_lookback_base]

ofi_pct   = math.round(ofi*100)
ofi_txt   = ofi_bull?"COMPRA "+str.tostring(math.abs(ofi_pct))+"%":ofi_bear?"VENTA "+str.tostring(math.abs(ofi_pct))+"%":"NEUTRAL "+str.tostring(ofi_pct)+"%"
ofi_color = ofi_bull?col_long:ofi_bear?col_short:col_neutral
ofi_div_txt = ofi_div_bear?"DIV OFI BEAR":ofi_div_bull?"DIV OFI BULL":"—"

// A5 — CVD
candle_delta = close>open?volume:close<open?-volume:0
is_new_day   = ta.change(time("D"))!=0
var float cvd_session = 0.0
cvd_session := (is_new_day or na(cvd_session))?candle_delta:cvd_session+candle_delta
cvd_ma    = ta.sma(cvd_session,20)
cvd_bull  = cvd_session>cvd_ma
cvd_slope = cvd_session-cvd_session[3]
cvd_accel = cvd_slope>cvd_slope[3]

// A6 — MOMENTUM MULTI-TF
mom_ltf_raw  = (close-close[tf_mom_lb])/math.max(close[tf_mom_lb],0.0001)*100
mom_ltf_norm = math.min(100,math.max(0,50+mom_ltf_raw*tf_mom_sens))
[close_1h] = request.security(syminfo.tickerid,"60", [close],lookahead=barmerge.lookahead_off)
[close_4h] = request.security(syminfo.tickerid,"240",[close],lookahead=barmerge.lookahead_off)
mom_1h_raw  = (close_1h-close_1h[3])/math.max(close_1h[3],0.0001)*100
mom_1h_norm = math.min(100,math.max(0,50+mom_1h_raw*tf_mom_1h_sens))
mom_4h_raw  = (close_4h-close_4h[3])/math.max(close_4h[3],0.0001)*100
mom_4h_norm = math.min(100,math.max(0,50+mom_4h_raw*tf_mom_4h_sens))
_cvd_factor    = cvd_bull and cvd_accel?5:cvd_bull?2:not cvd_bull and not cvd_accel?-5:-2
momentum_score = math.min(100,math.max(0,mom_ltf_norm*0.40+mom_1h_norm*0.35+mom_4h_norm*0.25+_cvd_factor))
mom_bull     = momentum_score>60
mom_bear     = momentum_score<40
mom_all_bull = mom_ltf_norm>55 and mom_1h_norm>55 and mom_4h_norm>55
mom_all_bear = mom_ltf_norm<45 and mom_1h_norm<45 and mom_4h_norm<45
mom_div_bull = mom_ltf_norm>60 and mom_4h_norm<45
mom_div_bear = mom_ltf_norm<40 and mom_4h_norm>55
_mom_state = mom_all_bull?"CONV▲":mom_all_bear?"CONV▼":mom_div_bull?"DIV LTF▲":mom_div_bear?"DIV LTF▼":momentum_score>=55?"ALCISTA":momentum_score<=45?"BAJISTA":"NEUTRAL"
_mom_dir   = momentum_score>=70?"▲▲":momentum_score>=55?"▲":momentum_score>=45?"—":momentum_score>=30?"▼":"▼▼"
mom_txt    = _mom_dir+" "+str.tostring(math.round(momentum_score))+" "+_mom_state
mom_color  = mom_div_bull or mom_div_bear?col_warn:momentum_score>=60?col_long:momentum_score<=40?col_short:color.silver

// A7 — ESTRUCTURA ICT
swing_h      = ta.highest(high,swing_len)
swing_l      = ta.lowest(low, swing_len)
prev_swing_h = ta.highest(high,swing_len)[swing_len]
prev_swing_l = ta.lowest(low, swing_len)[swing_len]

bos_bull    = close>prev_swing_h and bull
bos_bear    = close<prev_swing_l and bear
choch       = (bull and close<prev_swing_l) or (bear and close>prev_swing_h)
choch_first = choch and not choch[1]
_rev_hi20       = ta.highest(high, 20)
_rev_lo20       = ta.lowest(low,  20)
reversal_signal = choch and (close>_rev_hi20[1] or close<_rev_lo20[1])

range_h  = ta.highest(high,50)
range_l  = ta.lowest(low, 50)
range_mid= (range_h+range_l)/2
in_premium  = close>range_mid and bear
in_discount = close<range_mid and bull

f_imp_up(idx)=> close[idx]>open[idx] and (close[idx]-open[idx])>atr[idx]*0.8
f_imp_dn(idx)=> close[idx]<open[idx] and (open[idx]-close[idx])>atr[idx]*0.8
ob_bull_detected = close[ob_lookback]<open[ob_lookback] and f_imp_up(ob_lookback-1)
ob_bear_detected = close[ob_lookback]>open[ob_lookback] and f_imp_dn(ob_lookback-1)
ob_bull_top    = ob_bull_detected?open[ob_lookback] :na
ob_bull_bottom = ob_bull_detected?close[ob_lookback]:na
ob_bear_top    = ob_bear_detected?close[ob_lookback]:na
ob_bear_bottom = ob_bear_detected?open[ob_lookback] :na
price_in_bull_ob = not na(ob_bull_top)    and close<=ob_bull_top    and close>=ob_bull_bottom and bull
price_in_bear_ob = not na(ob_bear_top)    and close>=ob_bear_bottom and close<=ob_bear_top    and bear

var box ob_bull_box=na
var box ob_bear_box=na
if show_ob and barstate.islast
    if not na(ob_bull_bottom)
        ob_bull_box:=box.new(bar_index-ob_lookback,ob_bull_top,bar_index+5,ob_bull_bottom,border_color=color.new(col_long,30),bgcolor=color.new(col_long,88),border_width=1)
    if not na(ob_bear_bottom)
        ob_bear_box:=box.new(bar_index-ob_lookback,ob_bear_top,bar_index+5,ob_bear_bottom,border_color=color.new(col_short,30),bgcolor=color.new(col_short,88),border_width=1)

fvg_bull = low>high[2] and (low-high[2])/close*100>=fvg_min_size
fvg_bear = high<low[2] and (low[2]-high)/close*100>=fvg_min_size
fvg_bull_top    = fvg_bull?low    :na
fvg_bull_bottom=fvg_bull?high[2]:na
fvg_bear_top    = fvg_bear?low[2] :na
fvg_bear_bottom=fvg_bear?high   :na
price_filling_bull_fvg = close<=fvg_bull_top[1] and close>=fvg_bull_bottom[1] and bull
price_filling_bear_fvg = close>=fvg_bear_bottom[1] and close<=fvg_bear_top[1] and bear

if show_fvg
    if fvg_bull
        box.new(bar_index-2,fvg_bull_top,bar_index+3,fvg_bull_bottom,border_color=color.new(col_elite,20),bgcolor=color.new(col_elite,85),border_width=1,border_style=line.style_dashed)
    if fvg_bear
        box.new(bar_index-2,fvg_bear_top,bar_index+3,fvg_bear_bottom,border_color=color.new(col_warn,20),bgcolor=color.new(col_warn,85),border_width=1,border_style=line.style_dashed)

breaker_bull = ob_bear_detected and close>ob_bear_top  and close[1]<=ob_bear_top
breaker_bear = ob_bull_detected and close<ob_bull_bottom and close[1]>=ob_bull_bottom

is_week_start = not na(ta.change(time("W"))) and ta.change(time("W"))!=0
var float avwap_num=na
var float avwap_den=na
f_typ_x_vol()=> (high+low+close)/3*volume
avwap_num := (is_week_start or na(avwap_num) or avwap_den==0)?f_typ_x_vol():avwap_num+f_typ_x_vol()
avwap_den := (is_week_start or na(avwap_den) or avwap_den==0)?volume:avwap_den+volume
avwap       = avwap_den>0?avwap_num/avwap_den:close
avwap_dist  = (close-avwap)/close*100
above_avwap = close>avwap

ob_freshness  = (ob_bull_detected or ob_bear_detected)?math.max(0,100-ob_lookback*3):0
fvg_bull_size = fvg_bull?(low-high[2])/math.max(atr,0.0001)*100:0.0
fvg_bear_size = fvg_bear?(low[2]-high)/math.max(atr,0.0001)*100:0.0
fvg_strength  = math.min(100,math.max(fvg_bull_size,fvg_bear_size)*20)
ict_active    = (price_in_bull_ob or price_in_bear_ob)?40:(price_filling_bull_fvg or price_filling_bear_fvg)?35:(breaker_bull or breaker_bear)?25:0
avwap_align   = (above_avwap and bull) or (not above_avwap and bear)?20:0
struct_bonus  = choch_first?25:(bos_bull or bos_bear)?15:0
var float ict_quality=0.0
ict_quality := math.min(100,ob_freshness*0.20+fvg_strength*0.20+ict_active+avwap_align+struct_bonus)

liq_sweep_up   = high>ta.highest(high,20)[1]
liq_sweep_down = low <ta.lowest(low, 20)[1]
fake_move      = (liq_sweep_up and close<open) or (liq_sweep_down and close>open)
swing_dist_up  = (swing_h-close)/close*100
swing_dist_down= (close-swing_l)/close*100
liq_high_zone  = math.abs(swing_h-swing_h[swing_len])<atr*0.15
liq_low_zone   = math.abs(swing_l-swing_l[swing_len])<atr*0.15

liq_hunt_up   = close>(range_h+range_l)/2 and swing_dist_up  <1.0
liq_hunt_down = close<(range_h+range_l)/2 and swing_dist_down<1.0
liq_bonus     = (liq_hunt_up and liq_high_zone) or (liq_hunt_down and liq_low_zone)?20:(liq_high_zone or liq_low_zone)?10:0
ict_quality   := math.min(100,ict_quality+liq_bonus)

_ict_zona = price_in_bull_ob?"EN OB BULL":price_in_bear_ob?"EN OB BEAR":price_filling_bull_fvg?"FILL FVG BULL":price_filling_bear_fvg?"FILL FVG BEAR":breaker_bull?"BREAKER BULL":breaker_bear?"BREAKER BEAR":fvg_bull?"FVG BULL":fvg_bear?"FVG BEAR":ob_bull_detected?"OB BULL":ob_bear_detected?"OB BEAR":"Sin zona"
ict_quality_txt   = (ict_quality>=80?"ELITE ":ict_quality>=60?"FUERTE ":ict_quality>=40?"MEDIA ":ict_quality>=20?"DEBIL ":"SIN ")+str.tostring(math.round(ict_quality))+" · "+_ict_zona
ict_quality_color = ict_quality>=80?col_elite:ict_quality>=60?col_long:ict_quality>=40?color.yellow:ict_quality>=20?col_warn:col_neutral

_ph=ta.highest(high,14)
_pl=ta.lowest(low,14)
_rsi_hi14  = ta.highest(rsi, 14)
_rsi_lo14  = ta.lowest(rsi,  14)
_macd_hi14 = ta.highest(macd_hist, 14)
_macd_lo14 = ta.lowest(macd_hist,  14)
bear_div_rsi  = high>=_ph and rsi<_rsi_hi14[1] and bull
bull_div_rsi  = low<=_pl  and rsi>_rsi_lo14[1]  and bear
bear_div_macd = high>=_ph and macd_hist<_macd_hi14[1] and bull
bull_div_macd = low<=_pl  and macd_hist>_macd_lo14[1]  and bear
double_div_bear=bear_div_rsi and bear_div_macd
double_div_bull=bull_div_rsi and bull_div_macd
stoch_ob=stoch_k>80 and stoch_d>80
stoch_os=stoch_k<20 and stoch_d<20
stoch_cross_up  =ta.crossover(stoch_k,stoch_d)
stoch_cross_down=ta.crossunder(stoch_k,stoch_d)

// A8 — SESIÓN Y TIEMPO
utc_hour    = hour(time,"UTC")
in_session_a= utc_hour>=session_a_start and utc_hour<session_a_end
in_session_b= utc_hour>=session_b_start and utc_hour<session_b_end
in_asia     = utc_hour>=0 and utc_hour<6
in_session  = in_session_a or in_session_b
in_power_hour= utc_hour>=ph_start_hour and utc_hour<ph_end_hour

dow            = dayofweek(time,"UTC")
is_sunday_utc  = dow==dayofweek.sunday
is_monday_pre  = dow==dayofweek.monday and utc_hour<13
is_fomc_window = dow==dayofweek.wednesday and ((utc_hour==18 and minute<30) or (utc_hour==17 and minute>=45))
is_nfp_window  = dow==dayofweek.friday and ((utc_hour==12 and minute>=15) or (utc_hour==13 and minute<15))
is_news_window = exclude_news_window and (is_fomc_window or is_nfp_window)
session_blocked= (use_power_hour and not in_power_hour) or (exclude_sunday and is_sunday_utc) or (exclude_monday_pre and is_monday_pre)

dow_optimal = dow==dayofweek.tuesday or dow==dayofweek.wednesday or dow==dayofweek.thursday
dow_txt     = dow==2?"LUNES":dow==3?"MARTES":dow==4?"MIERCOLES":dow==5?"JUEVES":dow==6?"VIERNES":dow==7?"SABADO":"DOMINGO"
active_session = in_session_a?"SESION A "+str.tostring(session_a_start)+"-"+str.tostring(session_a_end)+"h":in_session_b?"SESION B "+str.tostring(session_b_start)+"-"+str.tostring(session_b_end)+"h":in_asia?"ASIA 00-06h":"OFF"
mins_left      = in_session_a?str.tostring((session_a_end-utc_hour)*60-minute)+"m":in_session_b?str.tostring((session_b_end-utc_hour)*60-minute)+"m":"—"

seconds_in_bar    = timeframe.in_seconds(timeframe.period)
elapsed_seconds   = math.round((timenow-time)/1000)
remaining_seconds = math.max(0,seconds_in_bar-elapsed_seconds)
remaining_mins    = math.floor(remaining_seconds/60)
remaining_secs    = remaining_seconds-remaining_mins*60
ctc_txt           = str.tostring(remaining_mins)+"m "+str.tostring(remaining_secs)+"s"
ctc_warning       = remaining_seconds<120

bar_gap      = math.abs(open-close[1])
is_gap_bar   = bar_gap>atr*2.0
var int bars_since_gap=9999
bars_since_gap:=is_gap_bar?0:bars_since_gap+1
gap_block    = gap_protect_bars>0 and bars_since_gap<gap_protect_bars
gap_block_txt= gap_block?"GAP RESTANTE "+str.tostring(gap_protect_bars-bars_since_gap)+"b":"OK"

// A9 — CORRELACIONES Y MACRO
dxy_close = request.security("TVC:DXY", timeframe.period,close,lookahead=barmerge.lookahead_off)
spy_close = request.security("AMEX:SPY",timeframe.period,close,lookahead=barmerge.lookahead_off)
ret_asset = math.log(close    /close[1])
ret_dxy   = math.log(dxy_close/dxy_close[1])
ret_spy   = math.log(spy_close/spy_close[1])
f_corr(x,y,n)=>
    mx=ta.sma(x,n)
    my=ta.sma(y,n)
    cov=ta.sma((x-mx)*(y-my),n)
    sx=math.sqrt(math.max(ta.sma(math.pow(x-mx,2),n),0.0))
    sy=math.sqrt(math.max(ta.sma(math.pow(y-my,2),n),0.0))
    denom=sx*sy
    denom>0.0001?cov/denom:0.0
corr_dxy = f_corr(ret_asset,ret_dxy,corr_lookback)
corr_spy = f_corr(ret_asset,ret_spy,corr_lookback)
dxy_roc    = (dxy_close-dxy_close[20])/dxy_close[20]*100
asset_roc  = (close-close[20])/close[20]*100
dxy_thr    = math.max(0.5,ta.percentile_linear_interpolation(math.abs(dxy_roc),100,75))
macro_headwind = dxy_roc> dxy_thr and asset_roc<-dxy_thr
macro_tailwind = dxy_roc<-dxy_thr and asset_roc> dxy_thr
dxy_corr_txt   = macro_headwind?"DXY FUERTE → PRESION":macro_tailwind?"DXY DEBIL → SOPORTE":"DXY NEUTRAL"
dxy_corr_col   = macro_headwind?col_short:macro_tailwind?col_long:col_neutral
spy_sma5        = ta.sma(ret_spy,5)
cross_risk_flag = math.abs(corr_spy)>corr_warn_thr and ret_spy<0 and spy_sma5<0 and not htf_long
cross_risk_mult = cross_risk_flag?0.6:1.0
corr_txt        = syminfo.ticker+"/DXY "+str.tostring(corr_dxy,"#.##")+"  "+syminfo.ticker+"/SPY "+str.tostring(corr_spy,"#.##")

// A10 — TEMPERATURA Y FEAR & GREED
_spd = math.abs(close-close[tf_speed_lb])/math.max(atr*tf_speed_lb,0.0001)*100
mkt_temp = math.min(100,math.max(0,math.min(100,_spd/math.max(ta.sma(_spd,tf_speed_ma),0.01)*50)*0.30+math.min(100,volume/math.max(vol_ma90,1)*50)*0.30+math.min(100,atr_ratio*50)*0.20+math.abs(rsi-50)*2*0.20))
mkt_temp_txt   = mkt_temp>=80?"CALIENTE "+str.tostring(math.round(mkt_temp)):mkt_temp>=55?"TIBIO "+str.tostring(math.round(mkt_temp)):mkt_temp>=30?"FRIO "+str.tostring(math.round(mkt_temp)):"MUERTO "+str.tostring(math.round(mkt_temp))
mkt_temp_color = mkt_temp>=80?col_short:mkt_temp>=55?col_warn:mkt_temp>=30?col_elite:col_neutral
fg_index=rsi*0.35+math.min(100,volume/math.max(vol_ma90,1)*50)*0.25+math.max(0,100-atr_ratio*50)*0.20+math.min(100,math.max(0,50+asset_roc*2))*0.20
fg_contrarian_long=fg_index<=20 and bull
fg_contrarian_short=fg_index>=80 and bear

// A11 — VOLATILIDAD Y SLIPPAGE
realized_vol_ann=math.max(ret_std*math.sqrt(math.max(bars_per_year,1.0)),0.01)
vol_scalar=math.min(vol_target_annual/realized_vol_ann,3.0)
vol_target_txt="VolTgt "+str.tostring(vol_target_annual*100,"#")+"% | Real "+str.tostring(math.round(realized_vol_ann*100))+"% | Sc "+str.tostring(math.round(vol_scalar*100))+"%"
vol_target_color=vol_scalar>1.2?col_long:vol_scalar<0.6?col_short:color.silver
slippage_cost=slippage_bps/10000.0
liquidity_cap=vol_ma*close*max_vol_part

// A12 — DISTANCIA HTF A EMAs CLAVE (D y W)
[ema50_w,ema200_w] = request.security(syminfo.tickerid,"W",[ta.ema(close,50),ta.ema(close,200)],lookahead=barmerge.lookahead_off)
dist_d_ema50  = (close-ema50_d) /close*100
dist_d_ema200 = (close-ema200_d)/close*100
dist_w_ema50  = (close-ema50_w) /close*100
dist_w_ema200 = (close-ema200_w)/close*100
_lvls_above = array.new<float>(0)
_lvls_below = array.new<float>(0)
_add_level(float lvl)=>
    if not na(lvl)
        if lvl>close
            array.push(_lvls_above,lvl)
        else if lvl<close
            array.push(_lvls_below,lvl)
_add_level(ema50_d)
_add_level(ema200_d)
_add_level(ema50_w)
_add_level(ema200_w)
htf_nearest_above  = array.size(_lvls_above)>0?array.min(_lvls_above):na
htf_nearest_below  = array.size(_lvls_below)>0?array.max(_lvls_below):na
dist_htf_above_pct = not na(htf_nearest_above)?(htf_nearest_above-close)/close*100:na
dist_htf_below_pct = not na(htf_nearest_below)?(close-htf_nearest_below)/close*100:na
htf_overextended   = not na(dist_htf_above_pct) and not na(dist_htf_below_pct) and dist_htf_above_pct>3.0 and dist_htf_below_pct>3.0
_htf_r = not na(dist_htf_above_pct)?"R +"+str.tostring(dist_htf_above_pct,"#.##")+"%":"R n/a"
_htf_s = not na(dist_htf_below_pct)?"S -"+str.tostring(dist_htf_below_pct,"#.##")+"%":"S n/a"
htf_dist_txt   = _htf_r+"  "+_htf_s+(htf_overextended?"  OVEREXT":"")
htf_dist_color = htf_overextended?col_warn:not na(dist_htf_above_pct) and dist_htf_above_pct<0.5?col_short:not na(dist_htf_below_pct) and dist_htf_below_pct<0.5?col_long:color.silver

// A13 — stub
atr_pct           = atr / close * 100

// A19 — CONTEXTO DE MERCADO EXTRA
// Vela diaria
[d_o,d_h,d_l,d_c,d_vol] = request.security(syminfo.tickerid,"D",[open,high,low,close,volume],lookahead=barmerge.lookahead_off)
d_rng       = math.max(d_h - d_l, 0.0001)
d_pos_pct   = (close - d_l) / d_rng * 100
d_dist_hi   = (d_h - close) / close * 100
d_dist_lo   = (close - d_l) / close * 100
d_bull      = d_c >= d_o

// VWAP diario (anclado al inicio del día UTC — crypto 24/7)
d_vwap      = ta.vwap
d_vwap_dist = (close - d_vwap) / close * 100
d_above_vwd = close > d_vwap

// RSI en 4H
rsi_4h = request.security(syminfo.tickerid,"240",ta.rsi(close,14),lookahead=barmerge.lookahead_off)

// Volumen 24h vs promedio 7 días (usando velas diarias)
d_vol_7d    = ta.sma(d_vol, 7)
d_vol_vs7d  = d_vol_7d > 0 ? d_vol / d_vol_7d * 100 : 100.0
vol_pctl_regime   = float(na)
vol_regime_detail = "—"
vol_regime_ctx_color = col_neutral
// A14 — stub
dow_num              = dayofweek(time,"UTC")
hour_utc             = utc_hour
session_elapsed_mins = -1
session_phase        = in_session ? "SESION" : "OFF"
session_phase_color  = in_session ? col_long : col_neutral
session_timing_txt   = session_phase
// A15 — stub
consec_ema20 = 0
trend_exhaustion = false
consec_txt = "—"
consec_color = col_neutral
// A16 — stub
ema_spread_pct = (ema50-ema200)/close*100
ema_spread_quality = math.abs(ema_spread_pct)>=1.0?"MODERADO":"DEBIL"
ema_spread_color = ema_spread_pct>0?col_long:col_short
ema_spread_txt = (ema_spread_pct>0?"BULL ":"BEAR ")+ema_spread_quality+" "+str.tostring(ema_spread_pct,"#.##")+"%"
// A17 — stub (POC)
poc_price    = float(na)
poc_dist_pct = 0.0
poc_near     = false
poc_txt      = "—"
poc_color    = col_neutral
// A18 — stub
corr_eth = 0.0
eth_decorr = false
corr_eth_txt = "—"
corr_eth_color = col_neutral
// A19 — WR POR RÉGIMEN → calculado en B8_EXT después del tracker

// A20 — FALTA INTELIGENTE → calculado después de B6 filtros

// MÓDULO B — ESTRATEGIA OPERATIVA

// B1 — SEÑALES DEL MODELO — parámetros automáticos por ticker+TF
// ── Tabla de lookup: auto-detecta activo y TF del chart ──────────────────────
// Actualizar cuando el VPS encuentra mejores modelos.

// Función 1: nombre de estrategia según ticker+TF
f_strat(_tk, _tf_m) =>
    string _r = "tma_bands"
    if str.contains(_tk,"BNB") and _tf_m==15
        _r := "consecutive_wick"
    if str.contains(_tk,"BNB") and _tf_m==60
        _r := "squeeze_expand_long"
    if str.contains(_tk,"BNB") and _tf_m==240
        _r := "breakout"
    if str.contains(_tk,"BTC") and _tf_m==15
        _r := "dmi_bear"
    if str.contains(_tk,"BTC") and _tf_m==60
        _r := "momentum"
    if str.contains(_tk,"BTC") and _tf_m==240
        _r := "three_candles_short"
    if str.contains(_tk,"BTC") and _tf_m==5
        _r := "momentum_short"
    if str.contains(_tk,"ETH") and _tf_m==15
        _r := "volatility_breakout"
    if str.contains(_tk,"ETH") and _tf_m==60
        _r := "breakout"
    if str.contains(_tk,"ETH") and _tf_m==240
        _r := "tma_bands"
    if str.contains(_tk,"ETH") and _tf_m==5
        _r := "volatility_breakout"
    if str.contains(_tk,"HG") and _tf_m==60
        _r := "lower_lows"
    if str.contains(_tk,"LTC") and _tf_m==15
        _r := "psar_flip"
    if str.contains(_tk,"LTC") and _tf_m==60
        _r := "williams_r"
    if str.contains(_tk,"LTC") and _tf_m==240
        _r := "bearish_rsi_divergence"
    if str.contains(_tk,"SOL") and _tf_m==15
        _r := "roc_negative_short"
    if str.contains(_tk,"SOL") and _tf_m==60
        _r := "breakdown"
    if str.contains(_tk,"SOL") and _tf_m==240
        _r := "supply_zone_rejection"
    if str.contains(_tk,"SOL") and _tf_m==5
        _r := "roc_negative_short"
    if str.contains(_tk,"XAU") and _tf_m==60
        _r := "regime_adaptive"
    _r

// Función 2: parámetros numéricos — índices: 0=sl 1=tp 2=cd 3=rw 4=lb 5=vm 6=tp2 7=am 8=et 9=re 10=ros 11=rmx 12=sl_s 13=tp_s 14=rwb 15=rwbr
f_nums(_tk, _tf_m) =>
    float[] _p = array.new<float>(16, 0.0)
    // defaults
    array.set(_p, 0, 2.0)  // sl_mult
    array.set(_p, 1, 3.0)  // tp_mult
    array.set(_p, 2, 5.0)  // cooldown
    array.set(_p, 3, 55.0)  // rsi_w_thr
    array.set(_p, 4, 30.0)  // lookback
    array.set(_p, 5, 1.5)  // vol_mult
    array.set(_p, 6, 14.0)  // tma_period
    array.set(_p, 7, 1.5)  // atr_mult
    array.set(_p, 8, 21.0)  // ema_type
    array.set(_p, 9, 45.0)  // rsi_entry
    array.set(_p, 10, 35.0)  // rsi_os
    array.set(_p, 11, 70.0)  // rsi_max
    array.set(_p, 12, 2.4)  // sl_mult_s
    array.set(_p, 13, 2.0)  // tp_mult_s
    array.set(_p, 14, 55.0)  // rsi_w_bull
    array.set(_p, 15, 47.0)  // rsi_w_bear
    // BNB/USDT 15m consecutive_wick CAGR:+27.4% WR:61% Grade:C
    if str.contains(_tk,"BNB") and _tf_m==15
        array.set(_p,0,3.5)
        array.set(_p,1,4.0)
        array.set(_p,2,10.0)
        array.set(_p,3,62.0)
    // BNB/USDT 1h squeeze_expand_long CAGR:+17.9% WR:82% Grade:B
    if str.contains(_tk,"BNB") and _tf_m==60
        array.set(_p,0,3.0)
        array.set(_p,1,1.5)
        array.set(_p,2,14.0)
        array.set(_p,3,50.0)
        array.set(_p,5,2.0)
    // BNB/USDT 4h breakout CAGR:+29.0% WR:78% Grade:A
    if str.contains(_tk,"BNB") and _tf_m==240
        array.set(_p,0,3.0)
        array.set(_p,1,2.9)
        array.set(_p,2,3.0)
        array.set(_p,3,62.0)
        array.set(_p,4,48.0)
        array.set(_p,5,1.2)
    // BTC/USDT 15m dmi_bear CAGR:+43.3% WR:63% Grade:B
    if str.contains(_tk,"BTC") and _tf_m==15
        array.set(_p,0,3.5)
        array.set(_p,1,3.2)
        array.set(_p,2,9.0)
        array.set(_p,3,62.0)
    // BTC/USDT 1h momentum CAGR:+32.0% WR:58% Grade:B
    if str.contains(_tk,"BTC") and _tf_m==60
        array.set(_p,0,2.7)
        array.set(_p,1,2.9)
        array.set(_p,2,12.0)
        array.set(_p,3,61.0)
        array.set(_p,5,1.2)
        array.set(_p,11,64.0)
    // BTC/USDT 4h three_candles_short CAGR:+24.3% WR:70% Grade:B
    if str.contains(_tk,"BTC") and _tf_m==240
        array.set(_p,0,2.8)
        array.set(_p,1,1.8)
        array.set(_p,2,3.0)
        array.set(_p,3,61.0)
        array.set(_p,5,1.0)
    // BTC/USDT 5m momentum_short CAGR:+6.6% WR:67% Grade:D
    if str.contains(_tk,"BTC") and _tf_m==5
        array.set(_p,0,2.9)
        array.set(_p,1,3.9)
        array.set(_p,2,11.0)
        array.set(_p,3,60.0)
        array.set(_p,5,2.3)
    // ETH/USDT 15m volatility_breakout CAGR:+77.6% WR:73% Grade:A
    if str.contains(_tk,"ETH") and _tf_m==15
        array.set(_p,0,3.4)
        array.set(_p,1,2.8)
        array.set(_p,2,4.0)
        array.set(_p,3,44.0)
    // ETH/USDT 1h breakout CAGR:+43.7% WR:85% Grade:A
    if str.contains(_tk,"ETH") and _tf_m==60
        array.set(_p,0,1.7)
        array.set(_p,1,2.5)
        array.set(_p,2,3.0)
        array.set(_p,3,51.0)
        array.set(_p,4,66.0)
        array.set(_p,5,3.5)
    // ETH/USDT 4h tma_bands CAGR:+19.8% WR:78% Grade:B
    if str.contains(_tk,"ETH") and _tf_m==240
        array.set(_p,0,3.0)
        array.set(_p,1,1.8)
        array.set(_p,2,11.0)
        array.set(_p,3,48.0)
        array.set(_p,6,19.0)
        array.set(_p,7,2.2)
    // ETH/USDT 5m volatility_breakout CAGR:+21.4% WR:73% Grade:C
    if str.contains(_tk,"ETH") and _tf_m==5
        array.set(_p,0,3.3)
        array.set(_p,1,3.5)
        array.set(_p,2,3.0)
        array.set(_p,3,61.0)
    // HG/USD 1h lower_lows CAGR:+64.0% WR:58% Grade:A
    if str.contains(_tk,"HG") and _tf_m==60
        array.set(_p,0,2.4)
        array.set(_p,1,3.1)
        array.set(_p,2,14.0)
        array.set(_p,3,61.0)
    // LTC/USDT 15m psar_flip CAGR:+15.8% WR:72% Grade:C
    if str.contains(_tk,"LTC") and _tf_m==15
        array.set(_p,0,3.2)
        array.set(_p,1,1.5)
        array.set(_p,2,5.0)
        array.set(_p,3,54.0)
    // LTC/USDT 1h williams_r CAGR:+130.5% WR:56% Grade:A+
    if str.contains(_tk,"LTC") and _tf_m==60
        array.set(_p,0,2.2)
        array.set(_p,1,2.9)
        array.set(_p,2,12.0)
        array.set(_p,3,44.0)
    // LTC/USDT 4h bearish_rsi_divergence CAGR:+39.7% WR:73% Grade:B
    if str.contains(_tk,"LTC") and _tf_m==240
        array.set(_p,0,2.6)
        array.set(_p,1,1.8)
        array.set(_p,2,8.0)
        array.set(_p,3,53.0)
        array.set(_p,4,17.0)
    // SOL/USDT 15m roc_negative_short CAGR:+35.7% WR:63% Grade:B
    if str.contains(_tk,"SOL") and _tf_m==15
        array.set(_p,0,3.2)
        array.set(_p,1,3.2)
        array.set(_p,2,3.0)
        array.set(_p,3,44.0)
    // SOL/USDT 1h breakdown CAGR:+36.9% WR:75% Grade:A
    if str.contains(_tk,"SOL") and _tf_m==60
        array.set(_p,0,2.0)
        array.set(_p,1,1.6)
        array.set(_p,2,12.0)
        array.set(_p,3,47.0)
        array.set(_p,4,53.0)
        array.set(_p,5,3.2)
    // SOL/USDT 4h supply_zone_rejection CAGR:+28.3% WR:70% Grade:A
    if str.contains(_tk,"SOL") and _tf_m==240
        array.set(_p,0,3.2)
        array.set(_p,1,2.2)
        array.set(_p,2,4.0)
        array.set(_p,3,61.0)
        array.set(_p,4,21.0)
        array.set(_p,5,1.3)
    // SOL/USDT 5m roc_negative_short CAGR:+29.6% WR:46% Grade:C
    if str.contains(_tk,"SOL") and _tf_m==5
        array.set(_p,0,1.9)
        array.set(_p,1,4.0)
        array.set(_p,2,3.0)
        array.set(_p,3,62.0)
    // XAU/USD 1h regime_adaptive CAGR:+205.1% WR:70% Grade:A+
    if str.contains(_tk,"XAU") and _tf_m==60
        array.set(_p,0,1.6)
        array.set(_p,1,3.2)
        array.set(_p,2,11.0)
        array.set(_p,3,58.0)
        array.set(_p,4,23.0)
        array.set(_p,5,1.9)
        array.set(_p,14,63.0)
        array.set(_p,15,32.0)
    _p

// Función 3: metadata del modelo (Grade|dias|WR%|WFT)
f_meta(_tk, _tf_m) =>
    string _r = "B|0|50|--"
    if str.contains(_tk,"BNB") and _tf_m==15
        _r := "C|0|61|FAIL"
    if str.contains(_tk,"BNB") and _tf_m==60
        _r := "B|0|82|--"
    if str.contains(_tk,"BNB") and _tf_m==240
        _r := "A|0|78|OK"
    if str.contains(_tk,"BTC") and _tf_m==15
        _r := "B|0|63|OK"
    if str.contains(_tk,"BTC") and _tf_m==60
        _r := "B|0|58|OK"
    if str.contains(_tk,"BTC") and _tf_m==240
        _r := "B|0|70|FAIL"
    if str.contains(_tk,"BTC") and _tf_m==5
        _r := "D|0|67|--"
    if str.contains(_tk,"ETH") and _tf_m==15
        _r := "A|0|73|OK"
    if str.contains(_tk,"ETH") and _tf_m==60
        _r := "A|0|85|OK"
    if str.contains(_tk,"ETH") and _tf_m==240
        _r := "B|0|78|OK"
    if str.contains(_tk,"ETH") and _tf_m==5
        _r := "C|0|73|FAIL"
    if str.contains(_tk,"HG") and _tf_m==60
        _r := "A|0|58|--"
    if str.contains(_tk,"LTC") and _tf_m==15
        _r := "C|0|72|OK"
    if str.contains(_tk,"LTC") and _tf_m==60
        _r := "A+|0|56|OK"
    if str.contains(_tk,"LTC") and _tf_m==240
        _r := "B|0|73|OK"
    if str.contains(_tk,"SOL") and _tf_m==15
        _r := "B|0|63|OK"
    if str.contains(_tk,"SOL") and _tf_m==60
        _r := "A|0|75|FAIL"
    if str.contains(_tk,"SOL") and _tf_m==240
        _r := "A|0|70|OK"
    if str.contains(_tk,"SOL") and _tf_m==5
        _r := "C|0|46|OK"
    if str.contains(_tk,"XAU") and _tf_m==60
        _r := "A+|0|70|--"
    _r

// Cargar parámetros automáticamente según ticker y TF del chart actual
strat_name = f_strat(_ticker, tf_mins)
_p         = f_nums(_ticker, tf_mins)
_meta      = f_meta(_ticker, tf_mins)
_meta_pts  = str.split(_meta, "|")
_m_grade   = array.size(_meta_pts)>0?array.get(_meta_pts,0):"?"
_m_age     = array.size(_meta_pts)>1?array.get(_meta_pts,1)+"d":"?"
_m_wr_txt  = array.size(_meta_pts)>2?"WR:"+array.get(_meta_pts,2)+"%":"WR:?"
_m_wft     = array.size(_meta_pts)>3?array.get(_meta_pts,3):"--"
_m_wft_col = _m_wft=="OK"?col_long:_m_wft=="FAIL"?col_short:col_neutral
m_sl_mult  = array.get(_p, 0)
m_tp_mult  = array.get(_p, 1)
m_cooldown = int(array.get(_p, 2))
m_rsi_w_b  = int(array.get(_p, 3))
m_lookback = int(array.get(_p, 4))
m_vol_mult = array.get(_p, 5)
m_tma_per  = int(array.get(_p, 6))
m_atr_mult = array.get(_p, 7)
m_ema_type = int(array.get(_p, 8))
m_rsi_ent  = int(array.get(_p, 9))
m_rsi_os   = int(array.get(_p,10))
m_rsi_max  = int(array.get(_p,11))
m_sl_s     = array.get(_p,12)
m_tp_s     = array.get(_p,13)
m_rsi_w_b2 = int(array.get(_p,14))  // rsi_w_bull para adaptive
m_rsi_w_br = int(array.get(_p,15))  // rsi_w_bear para adaptive

// ── Gate de régimen (idéntico al VPS) ─────────────────────────────────────────
m_vps_bull  = rsi_w > m_rsi_w_b and close > ema200
m_vps_range = rsi_w >= 40 and rsi_w <= m_rsi_w_b
m_vps_bear  = rsi_w < 40 or close < ema200 * 0.97
m_t_long    = (m_vps_bull or m_vps_range) and (not m_vps_range or rsi < 50)
m_t_short   = (m_vps_bear or m_vps_range) and (not m_vps_range or rsi > 52)

// ── Cooldown ──────────────────────────────────────────────────────────────────
var int m_last_sig = -500
m_in_cd = (bar_index - m_last_sig) < m_cooldown

// ── EMA para pullback — pre-calculada para cada valor posible (Pine v6: no series como length)
_ema21 = ta.ema(close, 21)
_ema34 = ta.ema(close, 34)
_ema50 = ta.ema(close, 50)
m_ema_pd = m_ema_type == 50 ? _ema50 : m_ema_type == 34 ? _ema34 : _ema21

// ── TMA Bands — pre-calculada para cada período posible
// [SIGMA-GEN-INDICATORS-START]
_tl14 = ta.sma(ta.sma(close, 14), 14)
_tl19 = ta.sma(ta.sma(close, 19), 19)
m_tma_line  = m_tma_per==14?_tl14 : m_tma_per==19?_tl19 : _tl19
m_tma_lower = m_tma_line - atr * m_atr_mult
m_tma_upper = m_tma_line + atr * m_atr_mult

_hi17 = ta.highest(high, 17)
_hi21 = ta.highest(high, 21)
_hi23 = ta.highest(high, 23)
_hi29 = ta.highest(high, 29)
_hi30 = ta.highest(high, 30)
_hi48 = ta.highest(high, 48)
_hi53 = ta.highest(high, 53)
_hi66 = ta.highest(high, 66)
_lo17 = ta.lowest(low,   17)
_lo21 = ta.lowest(low,   21)
_lo23 = ta.lowest(low,   23)
_lo29 = ta.lowest(low,   29)
_lo30 = ta.lowest(low,   30)
_lo48 = ta.lowest(low,   48)
_lo53 = ta.lowest(low,   53)
_lo66 = ta.lowest(low,   66)
_m_hi = m_lookback==17?_hi17 : m_lookback==21?_hi21 : m_lookback==23?_hi23 : m_lookback==29?_hi29 : m_lookback==30?_hi30 : m_lookback==48?_hi48 : m_lookback==53?_hi53 : m_lookback==66?_hi66 : _hi30
_m_lo = m_lookback==17?_lo17 : m_lookback==21?_lo21 : m_lookback==23?_lo23 : m_lookback==29?_lo29 : m_lookback==30?_lo30 : m_lookback==48?_lo48 : m_lookback==53?_lo53 : m_lookback==66?_lo66 : _lo30
// [SIGMA-GEN-INDICATORS-END]

// ── Señales por estrategia (una línea cada una — Pine v6) ────────────────────
_brk_l = close > _m_hi[1] and volume > vol_ma_20 * m_vol_mult
_brk_s = close < _m_lo[1] and volume > vol_ma_20 * m_vol_mult
_mom_l = macd_line > signal_line and macd_line[1] <= signal_line[1] and close > ema200 and volume > vol_ma_20 * m_vol_mult and rsi < m_rsi_max
_mom_s = macd_line < signal_line and macd_line[1] >= signal_line[1] and close < ema200 and volume > vol_ma_20 * m_vol_mult and rsi > (100 - m_rsi_max)
_adapt_long_ok = m_vps_bull or (m_vps_range and rsi < 50)

sig_breakout_l  = strat_name == "breakout"       and not m_in_cd and m_t_long  and _brk_l
sig_pullback_l  = strat_name == "pullback"        and not m_in_cd and m_t_long  and close > m_ema_pd and rsi < m_rsi_ent
sig_tma_l       = strat_name == "tma_bands"       and not m_in_cd and m_t_long  and close <= m_tma_lower and close > ema200
sig_mom_l       = strat_name == "momentum"        and not m_in_cd and m_t_long  and _mom_l
sig_mr_l        = strat_name == "mean_rev"        and not m_in_cd and m_t_long  and rsi < m_rsi_os and close > ema200
sig_breakdown_s = strat_name == "breakdown"       and not m_in_cd and m_t_short and _brk_s
sig_pullback_s  = strat_name == "pullback_short"  and not m_in_cd and m_t_short and close < m_ema_pd and rsi > (100 - m_rsi_ent)
sig_mom_s       = strat_name == "momentum_short"  and not m_in_cd and m_t_short and _mom_s
sig_adapt_l     = strat_name == "regime_adaptive" and not m_in_cd and _adapt_long_ok  and rsi_w > m_rsi_w_b  and close <= m_tma_lower and close > ema200
sig_adapt_s     = strat_name == "regime_adaptive" and not m_in_cd and not _adapt_long_ok and rsi_w < m_rsi_w_br and close >= m_tma_upper and close < ema200

// ── Estrategias agregadas 2026-05-14 (champions del sprint shorts expansion) ──
// break_of_structure — ruptura de swing high/low con volumen confirmando
_bos_period = math.max(5, math.round(m_lookback))
_bos_hi = ta.highest(high, _bos_period)
_bos_lo = ta.lowest(low,   _bos_period)
_bos_l = close > _bos_hi[1] and volume > vol_ma_20 * m_vol_mult
_bos_s = close < _bos_lo[1] and volume > vol_ma_20 * m_vol_mult
sig_bos_l = strat_name == "break_of_structure" and not m_in_cd and m_t_long  and _bos_l and rsi_w > 50
sig_bos_s = strat_name == "break_of_structure" and not m_in_cd and m_t_short and _bos_s and rsi_w < 50

// volatility_breakout — expansión de ATR + ruptura direccional
_vb_atr_ratio = atr / atr[20]
_vb_hi10 = ta.highest(high, 10)
_vb_lo10 = ta.lowest(low,  10)
_volb_l = _vb_atr_ratio > 1.3 and close > _vb_hi10[1] and volume > vol_ma_20 * 1.2
_volb_s = _vb_atr_ratio > 1.3 and close < _vb_lo10[1]  and volume > vol_ma_20 * 1.2
sig_volb_l = strat_name == "volatility_breakout" and not m_in_cd and m_t_long  and _volb_l
sig_volb_s = strat_name == "volatility_breakout" and not m_in_cd and m_t_short and _volb_s

// macd_zero_cross_down — MACD cruza desde >=0 hacia abajo
_macdzd = macd_line[1] >= 0 and macd_line < 0 and signal_line < 0 and close < ema200 and rsi > 25
sig_macdzd_s = strat_name == "macd_zero_cross_down" and not m_in_cd and m_t_short and _macdzd and rsi_w < 55

sig_willy_s  = false  // reservado
sig_willy_l  = false  // reservado: no hay modelo willy activo
sig_wedge_s  = false  // placeholder: wedge short no implementado
sig_dmi_s    = false  // placeholder: dmi short no implementado
sig_roc_s    = false  // placeholder: roc short no implementado
// ── Señal activa resultante ───────────────────────────────────────────────────
smart_long  = sig_breakout_l or sig_pullback_l or sig_tma_l or sig_mom_l or sig_mr_l or sig_adapt_l or sig_bos_l or sig_volb_l or sig_willy_l
smart_short = sig_breakdown_s or sig_pullback_s or sig_mom_s or sig_adapt_s or sig_bos_s or sig_volb_s or sig_macdzd_s or sig_wedge_s or sig_dmi_s or sig_roc_s
m_has_signal   = smart_long or smart_short
m_direction    = smart_long ? "LONG" : smart_short ? "SHORT" : "—"
m_is_short_str = str.contains(strat_name,"short") or str.contains(strat_name,"breakdown")
m_htf_confirm  = m_is_short_str ? (rsi_4h > 50 and not htf4_long) : (rsi_4h < 60 and htf4_long)
m_htf_txt      = m_htf_confirm ? "4H OK ✓" : "4H DIVERGE ⚠"
m_htf_col      = m_htf_confirm ? col_long : col_warn

// SL/TP del modelo (asimétrico en adaptive)
_sl_m = strat_name=="regime_adaptive" ? (smart_long?m_sl_mult:m_sl_s) : m_sl_mult
_tp_m = strat_name=="regime_adaptive" ? (smart_long?m_tp_mult:m_tp_s) : m_tp_mult

if m_has_signal
    m_last_sig := bar_index

// Mantener vars legacy que el código posterior puede referenciar
elite_long      = smart_long  and tf3_bull and price_in_bull_ob
elite_short     = smart_short and tf3_bear and price_in_bear_ob
elite_long_ict  = elite_long  and above_avwap
elite_short_ict = elite_short and not above_avwap
dual_long        = smart_long
dual_short       = smart_short
dual_mode_active = smart_long or smart_short
dual_dir         = smart_long?"LONG":smart_short?"SHORT":"—"

// B2 — SL / TP (usa parámetros del modelo)
// Niveles reales (solo cuando hay señal)
sl_price  = smart_long ?close-atr*_sl_m:smart_short?close+atr*_sl_m:na
tp_price  = smart_long ?close+atr*_tp_m:smart_short?close-atr*_tp_m:na
tp2_price = na(sl_price)?na:smart_long?close+atr*_tp_m*1.5:close-atr*_tp_m*1.5

_hyp_dir_long = m_vps_bull or (m_vps_range and rsi < 50)
sl_hyp  = _hyp_dir_long ? close-atr*m_sl_mult : close+atr*m_sl_s
tp1_hyp = _hyp_dir_long ? close+atr*m_tp_mult : close-atr*m_tp_s
tp2_hyp = _hyp_dir_long ? close+atr*m_tp_mult*1.5 : close-atr*m_tp_s*1.5

// Para display: usar real si hay señal, hipotético si no
sl_display  = not na(sl_price)  ? sl_price  : sl_hyp
tp1_display = not na(tp_price)  ? tp_price  : tp1_hyp
tp2_display = not na(tp2_price) ? tp2_price : tp2_hyp
sl_is_hyp   = na(sl_price)
tp_is_hyp   = na(tp_price)

sl_dist_display  = math.abs(close - sl_display)  / close * 100
tp1_dist_display = math.abs(tp1_display - close) / close * 100
rr_display       = sl_dist_display > 0 ? tp1_dist_display / sl_dist_display : 0.0

sl_dist_pct = not na(sl_price)?math.abs(close-sl_price)/close*100:0.0
tp_dist_pct = not na(tp_price)?math.abs(tp_price-close)/close*100:0.0
rr_ratio    = sl_dist_pct>0?tp_dist_pct/sl_dist_pct:0.0
rr_quality_mult = vol_expanding and not is_spike?1.05:vol_compressing and not is_spike?1.0:is_spike?0.5:0.85
rr_adjusted     = rr_ratio*rr_quality_mult
rr_quality_txt  = rr_adjusted>=3.0?"EXCEPCIONAL":rr_adjusted>=2.5?"EXCELENTE":rr_adjusted>=2.0?"BUENO":rr_adjusted>=1.5?"ACEPTABLE":rr_adjusted>0?"BAJO":"—"
// B2_EXT — NIVEL DE LIQUIDACIÓN Y FUNDING
// liq_price calculado en B7 donde ya existe leverage_impl
// Declarar vars aquí para que el HUD las encuentre
var float liq_price    = na
var float liq_dist_pct = na
var bool  liq_before_sl= false
var bool  liq_danger   = false
var string liq_txt     = "—"
var color  liq_color   = color.silver

// Funding rate — ciclos fijos Binance: 00:00, 08:00, 16:00 UTC
// Tiempo restante al próximo funding
// Funding cycles: 00:00, 08:00, 16:00 UTC — calcular el más cercano
_f0 = (0  - utc_hour) * 60 - minute
_f8 = (8  - utc_hour) * 60 - minute
_f16= (16 - utc_hour) * 60 - minute
_f0 := _f0  < 0 ? _f0  + 1440 : _f0
_f8 := _f8  < 0 ? _f8  + 1440 : _f8
_f16:= _f16 < 0 ? _f16 + 1440 : _f16
_mins_to_funding = math.min(_f0, math.min(_f8, _f16))
_next_funding_h  = _mins_to_funding == _f0 ? 0 : _mins_to_funding == _f8 ? 8 : 16

funding_mins_left  = _mins_to_funding
funding_warning    = funding_mins_left <= 15
funding_txt        = str.tostring(funding_mins_left) + "m para funding (" + str.tostring(_next_funding_h) + ":00 UTC)" + (funding_warning ? " EVITAR ENTRADA" : "")
funding_color      = funding_warning ? col_warn : funding_mins_left <= 30 ? color.yellow : color.silver

// TP1 AJUSTADO AL POC — si el POC está en el camino del TP, usarlo como target
tp1_adjusted    = tp_price
poc_blocks_tp   = false
if not na(poc_price) and not na(tp_price) and not na(sl_price)
    if smart_long and poc_price > close and poc_price < tp_price
        tp1_adjusted := poc_price
        poc_blocks_tp := true
    else if smart_short and poc_price < close and poc_price > tp_price
        tp1_adjusted := poc_price
        poc_blocks_tp := true

// Recalcular RR con TP1 ajustado
tp1_adj_dist_pct = not na(tp1_adjusted) ? math.abs(tp1_adjusted - close) / close * 100 : tp_dist_pct
rr_adjusted_poc  = sl_dist_pct > 0 ? tp1_adj_dist_pct / sl_dist_pct : rr_adjusted
tp1_poc_txt      = poc_blocks_tp ? str.tostring(tp1_adjusted, format.mintick) + " (POC adj, RR " + str.tostring(rr_adjusted_poc, "#.##") + ")" : not na(tp_price) ? str.tostring(tp_price, format.mintick) + " (ATR)" : "—"
tp1_poc_color    = poc_blocks_tp ? col_warn : col_long

// VOLUMEN RELATIVO HORARIO (vs misma hora ayer)
vol_same_hour_yesterday = volume[math.round(bars_per_day)]
vol_rel_hour = vol_same_hour_yesterday > 0 ? volume / vol_same_hour_yesterday * 100 : 100.0
vol_hour_unusual = vol_rel_hour > 150
vol_hour_txt     = str.tostring(math.round(vol_rel_hour)) + "% vs misma hora ayer" + (vol_hour_unusual ? " INUSUAL" : "")
vol_hour_color   = vol_rel_hour > 200 ? col_elite : vol_rel_hour > 150 ? col_long : vol_rel_hour < 60 ? col_neutral : color.silver

// SWING FRESHNESS — cuántas velas desde el último swing high/low
var int bars_since_swing_h = 0
var int bars_since_swing_l = 0
if barstate.isconfirmed
    if high >= swing_h
        bars_since_swing_h := 0
    else
        bars_since_swing_h := bars_since_swing_h + 1
    if low <= swing_l
        bars_since_swing_l := 0
    else
        bars_since_swing_l := bars_since_swing_l + 1

swing_h_fresh = bars_since_swing_h <= 5
swing_l_fresh = bars_since_swing_l <= 5
swing_fresh_txt   = "H: " + str.tostring(bars_since_swing_h) + "v " + (swing_h_fresh ? "FRESCO" : "viejo") + "  L: " + str.tostring(bars_since_swing_l) + "v " + (swing_l_fresh ? "FRESCO" : "viejo")
swing_fresh_color = (smart_long and swing_l_fresh) or (smart_short and swing_h_fresh) ? col_elite : color.silver

// CONGESTIÓN — penalización si precio lleva muchas velas en rango estrecho
var int bars_in_congestion = 0
_cong_range = ta.highest(high, 10) - ta.lowest(low, 10)
_is_congested = _cong_range < atr * 0.8
if barstate.isconfirmed
    bars_in_congestion := _is_congested ? bars_in_congestion + 1 : 0
congestion_penalty = bars_in_congestion >= 15
congestion_txt     = congestion_penalty ? "CONGESTION " + str.tostring(bars_in_congestion) + "v — reducir size" : bars_in_congestion > 5 ? "comprimido " + str.tostring(bars_in_congestion) + "v" : "OK"
congestion_color   = congestion_penalty ? col_warn : bars_in_congestion > 5 ? color.yellow : col_long

_ph_sl_el = ema20-atr*q_elite_sl
_ph_tp_el = ema20+atr*q_elite_tp
_ph_sl_es = ema20+atr*q_elite_sl
_ph_tp_es = ema20-atr*q_elite_tp
_ph_sl_xl = ema20-atr*q_exec_sl
_ph_tp_xl = ema20+atr*q_exec_tp
_ph_sl_xs = ema20+atr*q_exec_sl
_ph_tp_xs = ema20-atr*q_exec_tp
_ph_sl_wl = ema20-atr*q_watch_sl
_ph_tp_wl = ema20+atr*q_watch_tp
_ph_sl_ws = ema20+atr*q_watch_sl
_ph_tp_ws = ema20-atr*q_watch_tp

// B3 — SCORING
setup_long =(bull?20:0)+(strong_trend?20:0)+(htf_long?15:0)+(htf4_long?15:0)+(not fake_move?15:0)+(vol_expanding?15:0)
setup_short=(bear?20:0)+(strong_trend?20:0)+(htf_short?15:0)+(not htf4_long?15:0)+(not fake_move?15:0)+(vol_expanding?15:0)

timing_long =(macd_line>signal_line?22:0)+(rsi>50?18:0)+(volume_ok?18:0)+(cvd_bull?18:0)+(in_session?14:0)+(ofi_accel>0 and bull?10:0)
timing_short=(macd_line<signal_line?22:0)+(rsi<50?18:0)+(volume_ok?18:0)+(not cvd_bull?18:0)+(in_session?14:0)+(ofi_accel<0 and bear?10:0)

bonus_long=(tf4_bull?10:tf3_bull?5:0)+(elite_long?10:0)+(double_div_bull?5:0)+(not bb_squeeze and vol_expanding?5:0)+(price_in_bull_ob?8:0)+(price_filling_bull_fvg?6:0)+(above_avwap?4:0)+(fg_contrarian_long?5:0)+(ofi_bull?8:0)+(ofi_div_bull?6:0)+(regime_trend_up?5:0)+(in_discount?5:0)+(bull_div_rsi?4:0)+(bull_div_macd?3:0)
bonus_short=(tf4_bear?10:tf3_bear?5:0)+(elite_short?10:0)+(double_div_bear?5:0)+(not bb_squeeze and vol_expanding?5:0)+(price_in_bear_ob?8:0)+(price_filling_bear_fvg?6:0)+(not above_avwap?4:0)+(fg_contrarian_short?5:0)+(ofi_bear?8:0)+(ofi_div_bear?6:0)+(regime_trend_down?5:0)+(in_premium?5:0)+(bear_div_rsi?4:0)+(bear_div_macd?3:0)

sigma_score_long  = math.min(100,setup_long *setup_weight+timing_long *timing_weight+bonus_long)
sigma_score_short = math.min(100,setup_short*setup_weight+timing_short*timing_weight+bonus_short)
conf_is_long = sigma_score_long>=sigma_score_short
setup_score  = conf_is_long?setup_long :setup_short
timing_score = conf_is_long?timing_long:timing_short
sigma_score  = conf_is_long?sigma_score_long:sigma_score_short

// B4 — BAYESIANO + EV
p_f_tl=regime_trend_up?1.18:regime_trend_down?0.78:regime_ranging?0.95:0.85
p_f_ts=regime_trend_down?1.18:regime_trend_up?0.78:regime_ranging?0.95:0.85
p_f_il=price_in_bull_ob?1.12:price_filling_bull_fvg?1.08:above_avwap?1.04:0.98
p_f_is=price_in_bear_ob?1.12:price_filling_bear_fvg?1.08:not above_avwap?1.04:0.98
p_f_fl=ofi_bull?1.08:ofi_bear?0.88:1.0
p_f_fs=ofi_bear?1.08:ofi_bull?0.88:1.0
p_f_ml=tf4_bull?1.13:tf3_bull?1.07:not htf_long?0.86:1.0
p_f_ms=tf4_bear?1.13:tf3_bear?1.07:htf_long?0.86:1.0
p_f_pl=in_discount?1.06:in_premium?0.88:1.0
p_f_ps=in_premium?1.06:in_discount?0.88:1.0
p_bayes_long  = math.max(0.30,math.min(0.85,p_win_bull*p_f_tl*p_f_il*p_f_fl*p_f_ml*p_f_pl))
p_bayes_short = math.max(0.30,math.min(0.85,p_win_bear*p_f_ts*p_f_is*p_f_fs*p_f_ms*p_f_ps))
p_long_pct    = math.round(p_bayes_long*100)
p_short_pct   = math.round(p_bayes_short*100)
p_dominant    = math.max(p_long_pct,p_short_pct)
_rr_ev   = rr_adjusted>0?rr_adjusted:atr_tp_mult*regime_tp_mult/math.max(atr_sl_mult*regime_sl_mult,0.01)
ev_long  = p_bayes_long *_rr_ev-(1.0-p_bayes_long)
ev_short = p_bayes_short*_rr_ev-(1.0-p_bayes_short)
ev_bayes = conf_is_long?ev_long:ev_short
ev_ok    = ev_bayes>=min_ev_regime
ev_net   = not na(sl_price)?math.max(ev_bayes-(sl_dist_pct>0.01?2*slippage_cost/sl_dist_pct*100:0.0),-5.0):ev_bayes
ev_net_ok= ev_net>0

// B5 — CONFLUENCIA
conf_regime = (regime_trend_up and conf_is_long) or (regime_trend_down and not conf_is_long)?90:regime_ranging?50:regime_volatile?40:60
conf_pbayes = conf_is_long?p_long_pct:p_short_pct
_ct0  = in_session?30:in_asia?5:0
_ct1  = remaining_seconds>180?25:remaining_seconds>60?12:0
_ct2  = mkt_temp>=55?20:mkt_temp>=30?12:5
_ct3  = volume_ok?15:volume>vol_ma?8:0
_ct4  = not fake_move and not is_spike?10:fake_move?-20:-10
conf_timing = math.max(0,math.min(100,_ct0+_ct1+_ct2+_ct3+_ct4))
conf_flow = (ofi_bull and conf_is_long) or (ofi_bear and not conf_is_long)?85:(cvd_bull and cvd_accel and conf_is_long) or (not cvd_bull and not cvd_accel and not conf_is_long)?65:ofi_neutral?50:25
confluencia  = math.min(100,math.max(0,conf_regime*0.30+conf_pbayes*0.25+conf_timing*0.20+ict_quality*0.15+conf_flow*0.10))
conf_dir     = conf_is_long?"LONG":"SHORT"
_conf_level  = confluencia>=75?"FUERTE":confluencia>=60?"MEDIA":confluencia>=45?"DEBIL":"BAJA"
conf_color   = confluencia>=75?col_elite:confluencia>=60?col_long:confluencia>=45?color.yellow:confluencia>=30?col_warn:col_short
timing_real       = conf_timing
timing_real_color = timing_real>=75?col_elite:timing_real>=55?col_long:timing_real>=35?color.yellow:col_warn
timing_real_txt   = timing_real>=75?"OPTIMO "+str.tostring(math.round(timing_real)):timing_real>=55?"BUENO "+str.tostring(math.round(timing_real)):timing_real>=35?"REGULAR "+str.tostring(math.round(timing_real)):"MALO "+str.tostring(math.round(timing_real))

// B6 — CALIDADES Y FILTROS DUROS
_q_elite_long  = confluencia>=70 and (not hard_require_htf or htf_aligned_long)  and not is_high_vol and conf_is_long
_q_elite_short = confluencia>=70 and (not hard_require_htf or htf_aligned_short) and not is_high_vol and not conf_is_long
_q_exec_long   = confluencia>=50 and confluencia<70 and conf_is_long
_q_exec_short  = confluencia>=50 and confluencia<70 and not conf_is_long
_q_watch_long  = confluencia>=35 and confluencia<50 and conf_is_long
_q_watch_short = confluencia>=35 and confluencia<50 and not conf_is_long

hf_regime  =not (hard_block_volatil and is_high_vol)
hf_session =not session_blocked
hf_news    =not is_news_window
hf_gap     =not gap_block
hf_no_spike=not is_spike and not fake_move
hf_htf     =not hard_require_htf or htf_aligned
all_hard_filters_basic=hf_regime and hf_session and hf_news and hf_gap and hf_no_spike and hf_htf

var int last_loss_bar=-10000
var int consec_losses=0

in_cooldown = bar_index-last_loss_bar<hard_cooldown_bars and consec_losses>=hard_max_consec_losses

var array<float> rolling_arr=array.new<float>(0)
rolling_n=array.size(rolling_arr)
_rw  = 0
_rl  = 0
_rgw = 0.0
_rgl = 0.0
if rolling_n>0
    _st=math.max(0,rolling_n-auto_block_window)
    for i=_st to rolling_n-1
        _v=array.get(rolling_arr,i)
        if _v>0
            _rw  += 1
            _rgw += _v
        else if _v<0
            _rl  += 1
            _rgl += math.abs(_v)
rolling_active_n=math.min(rolling_n,auto_block_window)
rolling_wr=rolling_active_n>0?_rw/rolling_active_n:0.5
rolling_pf=_rgl>0.01?math.min(99.0,_rgw/_rgl):(_rgw>0?99.0:1.0)
auto_blocked=auto_block_enable and rolling_active_n>=auto_block_window and (rolling_wr<auto_block_min_wr or rolling_pf<auto_block_min_pf)

hf_cooldown =not in_cooldown
hf_not_block=not auto_blocked
all_hard_filters=all_hard_filters_basic and hf_cooldown and hf_not_block

_conf_min_required=(regime_trend_up or regime_trend_down)?hard_min_conf_trend:regime_ranging?hard_min_conf_range:999
hf_confluence=confluencia>=_conf_min_required
hf_rr        =rr_adjusted>=hard_min_rr
hf_ev_net_ok =ev_net>=hard_min_ev_net
all_filters_pass=all_hard_filters and hf_confluence and hf_rr and hf_ev_net_ok and dual_mode_active

ultra_pass=not ultra_strict_mode or (confluencia>=ultra_min_confluence and rr_adjusted>=ultra_min_rr and ev_net>=ultra_min_ev_net and all_hard_filters and vol_percentile<=ultra_max_vol_pctl and (not ultra_require_dual or dual_mode_active) and not auto_blocked)

hf_block_reason=not hf_not_block?"AUTO-BLOCK":not hf_regime?"reg.volatil":not hf_session?"off-session":not hf_news?"news":not hf_gap?"post-gap":not hf_cooldown?"cooldown "+str.tostring(hard_cooldown_bars-(bar_index-last_loss_bar))+"b":not hf_no_spike?"spike/trap":not hf_htf?"HTF no align":not hf_confluence?"conf<"+str.tostring(_conf_min_required):not hf_rr?"RR<"+str.tostring(hard_min_rr,"#.#"):not hf_ev_net_ok?"EV<min":not dual_mode_active?"sin modo":"—"

// A20 — FALTA INTELIGENTE (calculado aquí donde ya están los filtros)
_conf_gap  = _conf_min_required - confluencia
_rr_gap    = hard_min_rr - rr_adjusted
_ev_gap    = hard_min_ev_net - ev_net

_closest_cond = ""
_closest_dist = 9999.0
if _conf_gap > 0 and _conf_gap < _closest_dist
    _closest_dist := _conf_gap
    _closest_cond := "CONF a " + str.tostring(math.round(_conf_gap)) + "pts del umbral"
if _rr_gap > 0 and _rr_gap < _closest_dist
    _closest_dist := _rr_gap
    _closest_cond := "RR a " + str.tostring(_rr_gap, "#.##") + " del mínimo"
if not htf_aligned and _closest_dist > 1.0
    _closest_cond := "HTF pendiente de alinear"
if not volume_ok and _closest_dist > 2.0
    _closest_cond := "VOL bajo (" + str.tostring(math.round(volume / math.max(vol_ma, 1) * 100)) + "% de media)"

smart_missing_txt   = str.length(_closest_cond) > 0 ? "→ " + _closest_cond : "OK"
smart_missing_color = str.length(_closest_cond) > 0 and _conf_gap < 5 ? col_warn : str.length(_closest_cond) > 0 ? col_short : col_long

exec_long_v  = smart_long
exec_short_v = smart_short

_reg_txt = m_vps_bull?"BULL":m_vps_bear?"BEAR":"RANGE"
_fs1 = smart_long  and (elite_long_ict  or price_in_bull_ob) ? "ELITE+ ICT"           : ""
_fs2 = smart_long  and elite_long  and _fs1=="" ? "ELITE"                             : ""
_fs3 = smart_long  and _fs1=="" and _fs2==""    ? "EXECUTE LONG ("+strat_name+")"     : ""
_fs4 = smart_short and (elite_short_ict or price_in_bear_ob) ? "ELITE+ ICT SHORT"     : ""
_fs5 = smart_short and _fs4==""                 ? "EXECUTE SHORT ("+strat_name+")"    : ""
_fs6 = m_t_long or m_t_short                    ? "WATCH — "+_reg_txt+" ("+strat_name+")": ""
_fsx = _fs1!=""?_fs1:_fs2!=""?_fs2:_fs3!=""?_fs3:_fs4!=""?_fs4:_fs5!=""?_fs5:_fs6!=""?_fs6:"NO TRADE — régimen "+_reg_txt
final_status = auto_blocked ? "AUTO-BLOCK" : _fsx
_accion_dir  = m_direction
smart_entry  = m_has_signal?"EXECUTE "+m_direction+" · "+strat_name:"SIN SETUP · régimen "+_reg_txt

// B7 — SIZING Y KELLY
var array<float> kelly_wins_arr  =array.new<float>(0)
var array<float> kelly_losses_arr=array.new<float>(0)
var array<float> kelly_all_arr   =array.new<float>(0)
kelly_n     =array.size(kelly_all_arr)
kelly_n_wins=array.size(kelly_wins_arr)
kelly_n_loss=array.size(kelly_losses_arr)
kelly_p    =kelly_n>0?kelly_n_wins/kelly_n:0.5
kelly_q    =1.0-kelly_p
kelly_avg_win  =kelly_n_wins>0?array.avg(kelly_wins_arr) :rr_adjusted
kelly_avg_loss =kelly_n_loss>0?array.avg(kelly_losses_arr):1.0
kelly_b        =kelly_avg_loss>0?kelly_avg_win/kelly_avg_loss:rr_adjusted
kelly_f_raw    =kelly_b>0?(kelly_p*kelly_b-kelly_q)/kelly_b:0.0
kelly_f        =math.max(0.0,math.min(kelly_f_raw*kelly_fraction,0.20))
kelly_active   =use_kelly and kelly_n>=kelly_min_trades
kelly_risk_pct =kelly_active?kelly_f*100:risk_pct

dd_scalar=use_dd_scalar?(consec_losses>=dd_losses_l3?0.25:consec_losses>=dd_losses_l2?0.50:consec_losses>=dd_losses_l1?0.75:1.0):1.0
dd_txt   =consec_losses>=dd_losses_l3?"DD CRITICO 25% ("+str.tostring(consec_losses)+"L)":consec_losses>=dd_losses_l2?"DD ALTO 50% ("+str.tostring(consec_losses)+"L)":consec_losses>=dd_losses_l1?"DD MOD 75% ("+str.tostring(consec_losses)+"L)":"DD OK"
dd_color =consec_losses>=dd_losses_l3?col_short:consec_losses>=dd_losses_l2?col_warn:consec_losses>=dd_losses_l1?color.yellow:col_long

var float m_mean=0.0
var float m_m2=0.0
var int   m_count=0
if smart_long or smart_short
    m_count+=1
    float _d=ret-m_mean
    m_mean:=m_mean+_d/m_count
    float _d2=ret-m_mean
    m_m2:=m_m2+_d*_d2
m_std  =math.sqrt(math.max(m_count>1?m_m2/(m_count-1):0.0,0.0))
sharpe =m_std>0.0001?(m_mean/m_std)*math.sqrt(math.max(bars_per_year,1.0)):0.0
n_obs  =math.min(m_count,wf_window)
tstat  =m_std>0.0001?sharpe*math.sqrt(n_obs)/math.sqrt(1+math.pow(sharpe,2)/2):0.0
bonfactor=1.0+math.log(math.max(n_rules_tested,1))*0.3
edge_95  =tstat>=1.96*bonfactor
edge_99  =tstat>=2.58*bonfactor
edge_insuf=n_obs<wf_min_trades
edge_txt  =edge_insuf?"INSUF DATA ("+str.tostring(n_obs)+")":edge_99?"EDGE 99%":edge_95?"EDGE 95%":"EDGE NO VERIF"
edge_color=edge_insuf?col_neutral:edge_99?col_elite:edge_95?col_long:col_warn
edge_size_mult=edge_insuf?0.75:edge_99?1.0:edge_95?0.85:0.5

confluence_mult=math.max(0.50,math.min(1.0,confluencia/75.0))
p_bayes_mult   =math.max(0.65,math.min(1.0,(math.max(p_bayes_long,p_bayes_short)-0.40)/0.25))
temp_mult      =mkt_temp>=80?0.85:mkt_temp>=15?1.0:0.70

// Penalty correlación: DXY headwind o cross_risk activo → reducir size
corr_penalty = macro_headwind?0.70:cross_risk_flag?0.60:1.0
eff_risk_pct =math.max(0.0,math.min(kelly_risk_pct*dd_scalar*vol_scalar*cross_risk_mult*edge_size_mult*confluence_mult*p_bayes_mult*temp_mult*corr_penalty,5.0))
risk_amount  =capital*(eff_risk_pct/100)
_sl_pct_q    =sl_dist_pct>0?sl_dist_pct:atr/close*100*atr_sl_mult
pos_size_usd =math.min(_sl_pct_q>0?risk_amount/(_sl_pct_q/100):0.0,liquidity_cap)
pos_size_units=pos_size_usd>0 and close>0?pos_size_usd/close:0.0
leverage_impl =pos_size_usd>0?pos_size_usd/capital:0.0

// LIQ PRICE — calculado aquí donde leverage_impl ya existe
_lev_safe     = math.max(leverage_impl, 1.1)
_liq_raw      = smart_long ? close * (1.0 - 0.9 / _lev_safe) : smart_short ? close * (1.0 + 0.9 / _lev_safe) : float(na)
liq_price    := _liq_raw
liq_dist_pct := not na(_liq_raw) ? math.abs(close - _liq_raw) / close * 100 : float(na)
_liq_ls_long  = not na(_liq_raw) and not na(sl_price) and smart_long  and _liq_raw > sl_price
_liq_ls_short = not na(_liq_raw) and not na(sl_price) and smart_short and _liq_raw < sl_price
liq_before_sl := _liq_ls_long or _liq_ls_short
liq_danger    := not na(liq_dist_pct) and liq_dist_pct < 3.0
_liq_warn     = liq_before_sl ? "  LIQ ANTES SL!" : ""
liq_txt       := not na(_liq_raw) ? str.tostring(_liq_raw, format.mintick) + " (" + str.tostring(liq_dist_pct, "#.##") + "% dist)" + _liq_warn : "—"
liq_color     := liq_danger ? col_short : liq_before_sl ? col_warn : color.silver
size_tp1=pos_size_usd*0.50
size_tp2=pos_size_usd*0.30
size_tp3=pos_size_usd*0.20
max_gain =risk_amount*rr_adjusted
risk_ok  =rr_adjusted>=2.0 and not is_spike and not fake_move and ev_ok and ev_net_ok
risk_status=risk_ok?"RIESGO OK":not na(sl_price)?"REVISAR":"SIN TRADE"
risk_color =risk_ok?col_long:not na(sl_price)?col_warn:color.new(col_neutral,50)

// B8 — TRADE TRACKER CON BE MANAGEMENT
var float tt_entry=na
var float tt_sl=na
var float tt_tp1=na
var float tt_tp2=na
var bool tt_long=false
var bool tt_in=false
var int tt_bar=0
var int tt_bars_max=tt_bars_max_inp
var string tt_tipo=""
var float tt_rr=0.0
var bool tt_be=false
var bool tt_tp1hit=false
var float tt_partial=0.0
var string tt_result="—"
var float  tt_pnl=0.0
var int tt_held=0
var int tt_total=0
var int tt_wins=0
var int tt_losses=0
var float tt_pnl_total=0.0
var float tt_peak=0.0
var float tt_max_dd=0.0
var float tt_gross_win=0.0
var float tt_gross_loss=0.0

_trade_sig = m_has_signal and not na(sl_price)  // señal del modelo validada
if not tt_in and _trade_sig and not na(sl_price) and barstate.isconfirmed
    tt_in    :=true
    tt_bar   :=bar_index
    tt_entry :=close
    tt_sl    :=sl_price
    tt_tp1   :=tp_price
    tt_tp2   :=smart_long?close+math.abs(close-sl_price)*rr_adjusted*1.5:close-math.abs(close-sl_price)*rr_adjusted*1.5
    tt_long  :=smart_long
    tt_result:="ABIERTO"
    tt_tipo  :=elite_long_ict or elite_short_ict?"ELITE_ICT":elite_long or elite_short?"ELITE":"EXECUTE"
    tt_rr    :=rr_adjusted>0?rr_adjusted:1.33
    tt_be    :=false
    tt_tp1hit:=false
    tt_partial:=0.0

if tt_in and barstate.isconfirmed
    _bars=bar_index-tt_bar
    _eff_sl=tt_be?tt_entry:tt_sl
    _ht1=tt_long?high>=tt_tp1:low<=tt_tp1
    _ht2=tt_long?high>=tt_tp2:low<=tt_tp2
    _hsl=tt_long?low<=_eff_sl:high>=_eff_sl
    _gf=(tt_long and open>tt_tp1) or (not tt_long and open<tt_tp1)
    _to=_bars>=tt_bars_max
    _closed=false
    _cpnl=0.0

    if not use_be_after_tp1
        if _hsl and _ht1 and not _gf
            tt_result:="LOSS_AMBIG"
            _cpnl:=-1.0
            tt_losses+=1
            tt_gross_loss+=1.0
            _closed:=true
        else if _hsl and not _ht1
            tt_result:="LOSS"
            _cpnl:=-1.0
            tt_losses+=1
            tt_gross_loss+=1.0
            _closed:=true
        else if (_ht1 and not _hsl) or _gf
            tt_result:=_ht2?"WIN_TP2":"WIN_TP1"
            _cpnl:=_ht2?tt_rr*1.5:tt_rr
            tt_wins+=1
            tt_gross_win+=_cpnl
            _closed:=true
        else if _to
            _m=tt_long?(close-tt_entry)/math.abs(tt_entry-tt_sl):(tt_entry-close)/math.abs(tt_entry-tt_sl)
            tt_result:=_m>0.1?"BE+":_m<-0.1?"LOSS_SLOW":"BE"
            _cpnl:=_m
            if _m<0
                tt_losses+=1
                tt_gross_loss+=math.abs(_m)
            else
                tt_gross_win+=_m
            _closed:=true
    else
        if not tt_tp1hit
            if _hsl and _ht1 and not _gf
                tt_result:="LOSS_AMBIG"
                _cpnl:=-1.0
                tt_losses+=1
                tt_gross_loss+=1.0
                _closed:=true
            else if _hsl and not _ht1
                tt_result:="LOSS"
                _cpnl:=-1.0
                tt_losses+=1
                tt_gross_loss+=1.0
                _closed:=true
            else if _ht1 or _gf
                tt_tp1hit:=true
                tt_be:=true
                tt_partial:=tt_rr*0.5
                tt_result:="TP1_PARTIAL"
                if _ht2
                    _cpnl:=tt_partial+tt_rr*1.5*0.5
                    tt_result:="WIN_TP2_BE"
                    tt_wins+=1
                    tt_gross_win+=_cpnl
                    _closed:=true
            else if _to
                _m=tt_long?(close-tt_entry)/math.abs(tt_entry-tt_sl):(tt_entry-close)/math.abs(tt_entry-tt_sl)
                tt_result:=_m>0.1?"BE+":_m<-0.1?"LOSS_SLOW":"BE"
                _cpnl:=_m
                if _m<0
                    tt_losses+=1
                    tt_gross_loss+=math.abs(_m)
                else
                    tt_gross_win+=_m
                _closed:=true
        else
            if _ht2
                _cpnl:=tt_partial+tt_rr*1.5*0.5
                tt_result:="WIN_TP2_BE"
                tt_wins+=1
                tt_gross_win+=_cpnl
                _closed:=true
            else if _hsl
                _cpnl:=tt_partial
                tt_result:="WIN_PARTIAL_BE"
                tt_wins+=1
                tt_gross_win+=_cpnl
                _closed:=true
            else if _to
                _rp=tt_long?(close-tt_entry)/math.abs(tt_entry-tt_sl):(tt_entry-close)/math.abs(tt_entry-tt_sl)
                _cpnl:=tt_partial+_rp*0.5
                tt_result:=math.abs(_cpnl-tt_partial)<0.05?"BE_NEUTRAL":"WIN_TIMEOUT_BE"
                if _cpnl>0
                    tt_wins+=1
                    tt_gross_win+=_cpnl
                else
                    tt_losses+=1
                    tt_gross_loss+=math.abs(_cpnl)
                _closed:=true

    if _closed
        tt_total+=1
        tt_pnl:=_cpnl
        tt_pnl_total+=_cpnl
        tt_held:=_bars
        tt_in:=false
        array.push(kelly_all_arr,_cpnl)
        array.push(rolling_arr,_cpnl)
        if _cpnl>0
            array.push(kelly_wins_arr,_cpnl)
        else if _cpnl<0
            array.push(kelly_losses_arr,math.abs(_cpnl))
            consec_losses+=1
            last_loss_bar:=bar_index
        else
            consec_losses:=0
        if array.size(kelly_all_arr)>kelly_lookback
            array.shift(kelly_all_arr)
        if array.size(kelly_wins_arr)>kelly_lookback
            array.shift(kelly_wins_arr)
        if array.size(kelly_losses_arr)>kelly_lookback
            array.shift(kelly_losses_arr)
        if array.size(rolling_arr)>auto_block_window
            array.shift(rolling_arr)

tt_wr        =tt_total>0?tt_wins/tt_total:0.0
tt_expectancy=tt_total>0?tt_pnl_total/tt_total:0.0
tt_pf        =tt_gross_loss>0.01?math.min(99.0,tt_gross_win/tt_gross_loss):(tt_gross_win>0?99.0:0.0)
tt_pnl_disp  =math.max(-9999.0,math.min(9999.0,tt_pnl_total))
tt_peak      :=math.max(tt_peak,tt_pnl_total)
tt_max_dd    :=math.min(tt_max_dd,tt_pnl_total-tt_peak)
tt_calmar    =math.abs(tt_max_dd)>0.01?tt_pnl_total/math.abs(tt_max_dd):(tt_pnl_total>0?99.0:0.0)
tt_calmar_color=tt_calmar>=1.0?col_elite:tt_calmar>=0.5?col_long:tt_calmar>0?color.yellow:col_short
tt_live_grade=tt_total<5?"?":(tt_wr>=0.60 and tt_pf>=2.0 and tt_total>=10)?"A+":(tt_wr>=0.55 and tt_pf>=1.5 and tt_total>=10)?"A":(tt_wr>=0.50 and tt_pf>=1.2)?"B":tt_pf>=1.0?"C":"D"
// STREAK + DAILY R
var int tt_streak=0
var int tt_streak_best=0
var int tt_streak_worst=0
if tt_wins>nz(tt_wins[1])
    tt_streak:=tt_streak>=0?tt_streak+1:1
    tt_streak_best:=math.max(tt_streak_best,tt_streak)
if tt_losses>nz(tt_losses[1])
    tt_streak:=tt_streak<=0?tt_streak-1:-1
    tt_streak_worst:=math.max(tt_streak_worst,math.abs(tt_streak))
streak_txt=tt_streak==0?"—":tt_streak>0?str.tostring(tt_streak)+"W ▲  (max "+str.tostring(tt_streak_best)+"W)":str.tostring(math.abs(tt_streak))+"L ▼  (peor "+str.tostring(tt_streak_worst)+"L)"
streak_color=tt_streak>=3?col_elite:tt_streak>0?col_long:tt_streak<=-3?col_short:tt_streak<0?color.orange:color.silver
var float daily_r=0.0
var int daily_day=-1
_dom_now=dayofmonth(time)
if _dom_now!=daily_day
    daily_day:=_dom_now
    daily_r:=0.0
if tt_pnl_total!=nz(tt_pnl_total[1])
    daily_r:=daily_r+(tt_pnl_total-nz(tt_pnl_total[1]))
daily_r_txt=(daily_r>=0?"+":"")+str.tostring(daily_r,"#.##")+"R hoy"
daily_r_color=daily_r>0?col_long:daily_r<0?col_short:color.silver
tt_result_color=str.contains(tt_result,"WIN")?col_long:str.contains(tt_result,"LOSS")?col_short:tt_result=="TP1_PARTIAL" or tt_result=="BE_NEUTRAL"?col_elite:tt_result=="ABIERTO"?col_elite:color.silver

mae_avg       = 0.0
mfe_avg       = 0.0
cal_error     = float(na)
cal_status    = "—"
honest_warn   = tt_total < 30 ? "N=" + str.tostring(tt_total) + " insuficiente" : "Stats razonables"
honest_active = tt_total < 30

// Variables derivadas para HUD y JSON export
tt_mae_n       = 0
tt_mfe_n       = 0
sl_oversize    = false
tp_too_close   = false
mae_txt        = "—"
mfe_txt        = "—"
mae_color      = col_neutral
mfe_color      = col_neutral
active_mae_txt = "—"
active_mfe_txt = "—"
cal_exp_avg    = float(na)
cal_act_avg    = float(na)
cal_txt        = "—"
cal_color      = col_neutral
sharpe_recent  = float(na)
sharpe_prior   = float(na)
edge_deteriorating = false
overfit_risk   = false
overfit_txt    = "—"
overfit_color  = col_neutral
sharpe_roll_txt   = "—"
sharpe_roll_color = col_neutral
var string snap_regime   = "—"
var float  snap_conf     = 0.0
var float  snap_ofi      = 0.0
var float  snap_momentum = 0.0
var string snap_dir      = "—"
snap_txt       = "—"
snap_color     = col_neutral
wr_regime_val  = float(na)
_wr_n          = 0
wr_regime_txt  = "sin datos"
wr_regime_color = col_neutral

// B_EXT1-3 stubs
ctx_long=conf_is_long?5:-1
ctx_short=conf_is_long?-1:5
ctx_txt=conf_is_long?"▲ CTX LONG":"▼ CTX SHORT"
ctx_color=conf_is_long?col_long:col_short
sigma_ctx_diverge=false
conds_long=0
conds_short=0
conds_txt="—"
pl_exec_long_status="—"
pl_exec_short_status="—"
pl_long_txt="—"
pl_short_txt="—"
pl_long_color=col_long
pl_short_color=col_short
prob_layer_active="—"
prob_layer_color=col_neutral
// B_EXT4 — MISSING CONDITIONS MEJORADO
var string _miss = ""
_miss := (auto_blocked?"AUTO-BLOCK ":"")+(is_high_vol?"VOL-ALTO ":"")+(session_blocked?"OFF-SESSION ":"")+(is_news_window?"NEWS ":"")+(gap_block?"GAP ":"")+(in_cooldown?"COOLDOWN ":"")+(is_spike or fake_move?"SPIKE/TRAP ":"")+(not htf_aligned?"HTF ":"")+(not dual_mode_active?"SIN-MODO ":"")+(confluencia<_conf_min_required?"CONF<"+str.tostring(_conf_min_required)+" ":"")+(rr_adjusted<hard_min_rr?"RR<"+str.tostring(hard_min_rr,"#.#")+" ":"")+(ev_net<hard_min_ev_net?"EV-NETO ":"")+(not volume_ok?"VOL-BAJO ":"")+(mom_div_bull or mom_div_bear?"MOM-DIV ":"")
missing_detailed=str.length(_miss)>0?str.trim(_miss):"OK — todo pasa"
missing_color   =str.length(_miss)>0?col_warn:col_long

// B_EXT5 — SLIPPAGE + LIQ
liq_cap_usd    =liquidity_cap
liq_cap_ok     =pos_size_usd<=liq_cap_usd
slip_liq_txt   ="Slip "+str.tostring(slippage_bps,"#.#")+"bps  LiqCap $"+str.tostring(math.round(liq_cap_usd))+(liq_cap_ok?"  OK":"  SIZE>LIQ!")
slip_liq_color =liq_cap_ok?color.silver:col_warn

// B_EXT6 — SEÑALES HOY
var int signals_today=0
var int signals_today_long=0
var int signals_today_short=0
var int _last_day_sig=0
_cur_day=dayofmonth(time,"UTC")*100+month(time,"UTC")
if _cur_day!=_last_day_sig
    signals_today:=0
    signals_today_long:=0
    signals_today_short:=0
    _last_day_sig:=_cur_day
if m_has_signal and not gap_block and barstate.isconfirmed
    signals_today+=1
    if smart_long
        signals_today_long+=1
    else
        signals_today_short+=1
sig_today_txt  =str.tostring(signals_today)+" señales hoy  (▲"+str.tostring(signals_today_long)+" ▼"+str.tostring(signals_today_short)+")"
sig_today_color=signals_today>10?col_warn:signals_today>6?color.yellow:signals_today>0?col_long:col_neutral

// B10 — HUD COMPLETO
var hud=table.new(position.top_right,2,100,border_width=0,frame_width=1,frame_color=color.new(col_elite,50))
f_bar(v,hi)=>
    p=math.round(v/math.max(hi,1)*10)
    p>=10?"██████████":p>=8?"████████░░":p>=6?"██████░░░░":p>=4?"████░░░░░░":p>=2?"██░░░░░░░░":"█░░░░░░░░░"
method f_row(table self,int r,string lbl,string val,color vc)=>
    table.cell(self,0,r,lbl,text_color=color.rgb(140,155,190),bgcolor=color.rgb(14,18,36),text_size=size.tiny,text_font_family=font.family_monospace)
    table.cell(self,1,r,val,text_color=vc,bgcolor=color.rgb(14,18,36),text_size=size.tiny,text_font_family=font.family_monospace)
method f_row_big(table self,int r,string lbl,string val,color vc)=>
    table.cell(self,0,r,lbl,text_color=color.rgb(200,210,255),bgcolor=color.rgb(18,22,45),text_size=size.small,text_font_family=font.family_monospace)
    table.cell(self,1,r,val,text_color=vc,bgcolor=color.rgb(18,22,45),text_size=size.small,text_font_family=font.family_monospace)
method f_hdr(table self,int r,string lbl,color c)=>
    table.cell(self,0,r,lbl,text_color=c,bgcolor=color.new(c,80),text_size=size.tiny,text_font_family=font.family_monospace)
    table.cell(self,1,r,"",bgcolor=color.new(c,80))

if barstate.islast
    table.cell(hud,0,0,"SIGMA v13.0",text_color=color.rgb(255,200,0),bgcolor=color.rgb(5,8,20),text_size=size.small,text_font_family=font.family_monospace)
    table.cell(hud,1,0,syminfo.ticker+" · "+tf_label+" · "+asset_type_txt,text_color=color.rgb(100,140,200),bgcolor=color.rgb(5,8,20),text_size=size.small,text_font_family=font.family_monospace)

    // ── SEMAFORO: basado en señal del modelo ───────────────────────────────
    _lict = m_has_signal and (price_in_bull_ob or price_in_bear_ob)
    _lx   = m_has_signal and not _lict
    _lw   = not m_has_signal and (m_t_long or m_t_short)
    _lblk = auto_blocked
    _dir_arrow = smart_long ? " ▲ LONG" : " ▼ SHORT"
    _sem  = _lict?"✦✦ "+strat_name+_dir_arrow+" ICT":_lx?"● "+strat_name+_dir_arrow:_lw?(in_session?"◎ WATCH · "+_reg_txt:"◎ OFF · "+_reg_txt):(in_session?"○ NO TRADE · "+_reg_txt:"○ OFF · "+_reg_txt)
    _sfg  = _lict?color.white:_lx?(smart_long?col_long:col_short):_lw?color.yellow:_lblk?col_short:col_neutral
    _sbg  = _lict?color.new(col_elite,10):_lx?color.new(_sfg,20):_lw?color.new(color.yellow,20):_lblk?color.new(col_short,20):color.new(col_neutral,20)
    table.cell(hud,0,1,"SEMAFORO",text_color=color.rgb(200,200,200),bgcolor=color.rgb(10,14,30),text_size=size.small,text_font_family=font.family_monospace)
    table.cell(hud,1,1,_sem,text_color=_sfg,bgcolor=_sbg,text_size=size.small,text_font_family=font.family_monospace)

    // ── ACCION: dirección + contexto ICT ──────────────────────────────────
    _ae  = m_has_signal?" @"+str.tostring(close,format.mintick)+(price_in_bull_ob or price_in_bear_ob?" [OB]":"")+(price_filling_bull_fvg or price_filling_bear_fvg?" [FVG]":""):""
    _aw  = m_has_signal?m_direction+" · "+strat_name+_ae:_lw?"MONITOREAR · "+_reg_txt+(fake_move?" · TRAP":""):_lblk?"AUTO-BLOCK":fake_move?"TRAP ACTIVO":"SIN SETUP"
    _ac  = m_has_signal?(smart_long?col_long:col_short):_lw?color.yellow:col_neutral
    table.cell(hud,0,2,"ACCION",text_color=color.rgb(200,200,200),bgcolor=color.rgb(10,14,30),text_size=size.small,text_font_family=font.family_monospace)
    table.cell(hud,1,2,_aw,text_color=_ac,bgcolor=color.new(_ac,85),text_size=size.small,text_font_family=font.family_monospace)

    // ── DECISION: con SL/TP del modelo ────────────────────────────────────
    _rr_txt = rr_display > 0 ? "RR "+str.tostring(rr_display,"#.#") : ""
    _sl_txt = not na(sl_price) ? "SL "+str.tostring(sl_price,format.mintick) : ""
    _tp_txt = not na(tp_price) ? "TP "+str.tostring(tp_price,format.mintick) : ""
    _dc  = _lblk?"AUTO-BLOCK — no operar":m_has_signal?"EJECUTAR "+m_direction+" · "+_rr_txt+" · "+_sl_txt+" · "+_tp_txt:_lw?"VIGILAR — "+strat_name+" buscando entrada":"FUERA — régimen "+_reg_txt
    _dcc = _lblk?col_short:m_has_signal?col_elite:_lw?col_long:col_neutral
    table.cell(hud,0,3,"DECISION",text_color=color.white,bgcolor=color.rgb(40,30,5),text_size=size.normal,text_font_family=font.family_monospace)
    table.cell(hud,1,3,_dc,text_color=_dcc,bgcolor=color.new(_dcc,80),text_size=size.normal,text_font_family=font.family_monospace)
    _mod_gc  = _m_grade=="A+"?col_elite:_m_grade=="A"?col_long:_m_grade=="B"?color.yellow:col_warn
    _wft_ico = _m_wft=="OK"?"WFT:OK":_m_wft=="FAIL"?"WFT:FAIL":"WFT:--"
    // MODELO y AUDITORIA se muestran dentro del MODULO B, junto a ESTRATEGIA (filas 56-57)

    hud.f_hdr(6,"── MODULO A · CONTEXTO ──",color.rgb(0,210,255))
    hud.f_row(7, "REGIMEN",    regime_txt+"  "+dual_mode_txt,           regime_color)
    hud.f_row(8, "DETALLE",    regime_detail,                           color.silver)
    hud.f_row(9, "CONFLUENCIA",conf_dir+" "+str.tostring(math.round(confluencia))+"  "+_conf_level+"  "+f_bar(confluencia,100), conf_color)
    hud.f_row(10,"MOMENTUM",   mom_txt+"  LTF:"+str.tostring(math.round(mom_ltf_norm))+" 1H:"+str.tostring(math.round(mom_1h_norm))+" 4H:"+str.tostring(math.round(mom_4h_norm)), mom_color)
    hud.f_row(11,"TEMP",       mkt_temp_txt+"  "+f_bar(mkt_temp,100),  mkt_temp_color)
    hud.f_row(12,"TIMING",     timing_real_txt+"  "+f_bar(timing_real,100), timing_real_color)
    hud.f_row(13,"OFI",        ofi_txt,                                 ofi_color)
    hud.f_row(14,"OFI DIV",    ofi_div_txt,                             ofi_div_bull?col_elite:ofi_div_bear?col_warn:col_neutral)
    hud.f_row(15,"CVD",        (cvd_bull?"COMPRA ":"VENTA ")+(cvd_accel?"ACCEL":"FLAT"), cvd_bull?col_long:col_short)
    hud.f_row(16,"ICT",        ict_quality_txt,                         ict_quality_color)
    hud.f_row(17,"AVWAP",      (above_avwap?"SOBRE ":"BAJO ")+str.tostring(avwap_dist,"#.##")+"%", above_avwap?col_long:col_short)
    hud.f_row(18,"OB/FVG/BRK", (price_in_bull_ob or price_in_bear_ob?"OB✦ ":"OB- ")+(fvg_bull or fvg_bear?"FVG✦ ":"FVG- ")+(breaker_bull or breaker_bear?"BRK✦":"BRK-"), color.silver)
    hud.f_row(19,"STRUCT",     bos_bull?"BOS ↑":bos_bear?"BOS ↓":choch_first?"CHoCH":"—", bos_bull?col_long:bos_bear?col_short:choch_first?color.purple:color.gray)
    hud.f_row(20,"P/D ZONE",   in_premium?"PREMIUM SHORT":in_discount?"DISCOUNT LONG":"FAIR VALUE", in_premium?col_short:in_discount?col_long:color.silver)
    hud.f_row(21,"HTF ALIGN",  "1H "+(htf_long?"▲":"▼")+" 4H "+(htf4_long?"▲":"▼")+" D "+(htfd_long?"▲":"▼")+"  "+(tf4_bull?"4TF BULL":tf4_bear?"4TF BEAR":tf3_bull?"3TF BULL":tf3_bear?"3TF BEAR":"MIXTO"), tf4_bull or tf3_bull?col_long:tf4_bear or tf3_bear?col_short:color.silver)
    hud.f_row(22,"RSI",        str.tostring(rsi,"#.#")+"  "+f_bar(rsi,100), rsi>70?col_short:rsi<30?col_long:color.silver)
    hud.f_row(23,"STOCH",      stoch_ob?"SOBRECOMPRA":stoch_os?"SOBREVENTA":stoch_cross_up?"CROSS UP ↑":stoch_cross_down?"CROSS DOWN ↓":"NEUTRAL", stoch_ob?col_short:stoch_os?col_long:color.silver)
    hud.f_row(24,"MACD",       macd_line>signal_line?"BULL hist +"+str.tostring(macd_hist,"#.######"):"BEAR hist "+str.tostring(macd_hist,"#.######"), macd_line>signal_line?col_long:col_short)
    hud.f_row(25,"CANDLE",     candle_pattern_txt, color.silver)
    hud.f_row(26,"DIV",        (bear_div_rsi?"RSI bear ":"")+(bull_div_rsi?"RSI bull ":"")+(double_div_bear?"DOBLE BEAR":"")+(double_div_bull?"DOBLE BULL":"")+(not bear_div_rsi and not bull_div_rsi and not double_div_bear and not double_div_bull?"—":""), double_div_bull or bull_div_rsi?col_long:double_div_bear or bear_div_rsi?col_short:col_neutral)
    hud.f_row(27,"VOL BAR",    (vol_expanding?"EXPAND":vol_compressing?"SQUEEZE":"NEUTRAL")+" "+str.tostring(math.round(volume/math.max(vol_ma,1)*100))+"%", vol_expanding?col_long:vol_compressing?col_warn:color.silver)
    hud.f_row(28,"TRAP",       fake_move?"TRAP":"CLEAN", fake_move?col_warn:col_long)
    hud.f_row(29,"F&G PROXY",  "NEUTRAL "+str.tostring(math.round(fg_index))+(fg_index>=80?" GREED":fg_index<=20?" FEAR":""), fg_index>=80?col_short:fg_index<=20?col_long:color.silver)
    hud.f_row(30,"SWING H/L",  swing_fresh_txt,                         swing_fresh_color)
    hud.f_row(33,"SESION",     active_session+" · "+mins_left+" · "+dow_txt+(dow_optimal?" ✓":" —"), in_session?col_long:color.gray)
    hud.f_row(34,"CTC / GAP",  ctc_txt+(gap_block?" · "+gap_block_txt:""), ctc_warning or gap_block?col_warn:color.silver)
    _rsiw_col = m_vps_bull?col_long:m_vps_bear?col_short:color.yellow
    _rsiw_lbl = m_vps_bull?"BULL":m_vps_bear?"BEAR":"RANGE"
    hud.f_row_big(35,"RSI-W", str.tostring(rsi_w,"#.#")+"  "+_rsiw_lbl+"  (umbral "+str.tostring(m_rsi_w_b)+")", _rsiw_col)
    _cd_rem   = math.max(0, m_cooldown - (bar_index - m_last_sig))
    _cd_txt   = m_in_cd ? str.tostring(_cd_rem)+"b bloqueado · "+strat_name : "OK · "+strat_name+" listo"
    hud.f_row(36,"MODEL CD",  _cd_txt, m_in_cd?col_warn:col_long)
    hud.f_row(37,"HTF DIST",   htf_dist_txt, htf_dist_color)
    _vd_dir = d_bull?"▲ alcista":"▼ bajista"
    _vd_pos = str.tostring(math.round(d_pos_pct))+"%"
    hud.f_row(38,"VELA D",     _vd_dir+"  "+_vd_pos+" del rango  ["+str.tostring(d_h,format.mintick)+" - "+str.tostring(d_l,format.mintick)+"]", d_pos_pct>70?(d_bull?col_long:col_warn):d_pos_pct<30?(d_bull?col_warn:col_short):color.silver)
    hud.f_row(39,"VWAP D",     (d_above_vwd?"SOBRE ":"BAJO ")+str.tostring(d_vwap_dist,"#.##")+"% · "+str.tostring(d_vwap,format.mintick), d_above_vwd?col_long:col_short)
    _vd_v7 = math.round(d_vol_vs7d)
    hud.f_row(40,"VOL 24H",    str.tostring(_vd_v7)+"%  vs prom 7D"+(_vd_v7>150?" INUSUAL":_vd_v7>120?" ALTO":_vd_v7<70?" BAJO":" NORMAL"), _vd_v7>150?col_elite:_vd_v7>120?col_long:_vd_v7<70?col_neutral:color.silver)
    hud.f_row_big(41,"RSI 4H", str.tostring(rsi_4h,"#.#")+"  "+f_bar(rsi_4h,100)+(rsi_4h>70?" SOBRECOMPRA":rsi_4h<30?" SOBREVENTA":rsi_4h>55?" alcista":rsi_4h<45?" bajista":" neutral"), rsi_4h>70?col_short:rsi_4h<30?col_long:rsi_4h>55?col_long:rsi_4h<45?col_short:color.silver)
    hud.f_row(42,"DIST DIA",   "▲ "+str.tostring(d_dist_hi,"#.##")+"% al máx  ▼ "+str.tostring(d_dist_lo,"#.##")+"% al mín", d_dist_hi<0.5?col_warn:d_dist_lo<0.5?col_elite:color.silver)
    hud.f_row_big(43,"4H CONFIRM", m_htf_txt+"  RSI4H:"+str.tostring(rsi_4h,"#.#")+"  HTF4:"+str.tostring(htf4_long?"BULL":"BEAR"), m_htf_col)

    hud.f_hdr(49,"── MODULO B · ESTRATEGIA ──",color.rgb(80,220,120))
    hud.f_row(50,"P(exito)",   "▲ "+str.tostring(p_long_pct)+"% ▼ "+str.tostring(p_short_pct)+"%  EV"+(ev_bayes>=0?"+":"")+str.tostring(ev_bayes,"#.##")+"R", p_dominant>=65?col_elite:p_dominant>=55?col_long:color.yellow)
    hud.f_row(51,"EV NETO",    (ev_net>=0?"EV neto +":"EV neto ")+str.tostring(ev_net,"#.##")+"R  bruto "+(ev_bayes>=0?"+":"")+str.tostring(ev_bayes,"#.##")+"R", ev_net>0?col_long:col_short)
    hud.f_row_big(52,"RR",     "1:"+str.tostring(rr_display,"#.##")+"  "+rr_quality_txt+(sl_is_hyp?" ~":""), rr_display>=2.0?col_long:color.silver)
    hud.f_row_big(53,"SL",     str.tostring(sl_display,format.mintick)+" (-"+str.tostring(sl_dist_display,"#.##")+"%)"+(sl_is_hyp?" ~":""), sl_is_hyp?color.new(col_short,40):col_short)
    hud.f_row_big(54,"TP1",    (tp_is_hyp?"~":"")+str.tostring(tp1_display,format.mintick)+" (+"+str.tostring(tp1_dist_display,"#.##")+"%)"+(poc_blocks_tp?" POC":""), tp_is_hyp?color.new(col_long,40):tp1_poc_color)
    hud.f_row_big(55,"ESTRATEGIA", strat_name+_dir_arrow+(m_has_signal?" ● SEÑAL":sl_is_hyp?" (posible)":""), m_has_signal?(smart_long?col_long:col_short):sl_is_hyp?color.new(smart_long?col_long:col_short,25):(smart_long?col_long:col_short))
    hud.f_row(56,"MODELO",     strat_name+" · "+_reg_txt+" · "+_m_grade+" · "+_m_wr_txt+" · "+_wft_ico+(m_has_signal?" ● SEÑAL":""), m_has_signal?(smart_long?col_long:col_short):_m_wft_col)
    hud.f_row(57,"AUDITORIA",  honest_warn+"  "+_m_grade+" "+_m_wr_txt+" WFT:"+_m_wft, (honest_active or _m_wft=="FAIL")?col_warn:_mod_gc)
    hud.f_row(58,"SIGMA",      "▲ "+str.tostring(math.round(sigma_score_long))+"  ▼ "+str.tostring(math.round(sigma_score_short))+"  "+f_bar(sigma_score,100), conf_is_long?col_long:col_short)
    hud.f_row(59,"SHARPE",     str.tostring(sharpe,"#.##")+"  t="+str.tostring(tstat,"#.##"), sharpe>=1.0?col_elite:sharpe>=0.5?col_long:sharpe>0?color.yellow:col_short)
    hud.f_row(60,"KELLY",      kelly_active?"f*="+str.tostring(kelly_f*100,"#.##")+"% p="+str.tostring(kelly_p*100,"#")+"%":"FIJO "+str.tostring(risk_pct,"#.#")+"%", kelly_active and kelly_f>0.02?col_long:color.silver)
    hud.f_row(61,"DD",         dd_txt, dd_color)
    hud.f_row(63,"SIZE",       "$"+str.tostring(math.round(pos_size_usd))+" ("+str.tostring(pos_size_units,"#.####")+")", col_elite)
    hud.f_row(65,"MAX LOSS",   "-$"+str.tostring(math.round(risk_amount))+" (-"+str.tostring(eff_risk_pct,"#.##")+"%)", col_short)
    hud.f_row(66,"LEVERAGE",   str.tostring(leverage_impl,"#.##")+"x", leverage_impl>10?col_warn:color.silver)
    hud.f_row(67,"LIQUIDACION",liq_txt, liq_color)
    hud.f_row(68,"FUNDING",    funding_txt, funding_color)
    hud.f_row(69,"SLIP/LIQ",   slip_liq_txt, slip_liq_color)
    hud.f_row(70,"SEÑALES HOY",sig_today_txt, sig_today_color)

    _gate_open = m_t_long or m_t_short
    _mf = auto_blocked?"AUTO-BLOCK":m_in_cd?str.tostring(math.max(0,m_cooldown-(bar_index-m_last_sig)))+"b cooldown":not _gate_open?"RSI-W "+str.tostring(rsi_w,"#.#")+" fuera de rango (umbral "+str.tostring(m_rsi_w_b)+")":strat_name=="breakout"?"breakout: espera cierre > "+str.tostring(_m_hi[1],format.mintick):strat_name=="breakdown"?"breakdown: espera cierre < "+str.tostring(_m_lo[1],format.mintick):strat_name=="momentum_short"?"momentum: espera MACD cross bajista":strat_name=="tma_bands"?"tma_bands: espera precio en banda inferior":strat_name=="pullback"?"pullback: espera retroceso a EMA":strat_name=="mean_rev"?"mean_rev: espera RSI < "+str.tostring(m_rsi_os):"esperando señal · "+strat_name
    _mfc = auto_blocked?col_short:m_in_cd?col_warn:not _gate_open?col_short:col_long
    hud.f_row(79,"FALTA",      _mf, _mfc)

    hud.f_hdr(80,"── TRACKER ──",color.rgb(255,200,0))
    _be_tag=tt_in and tt_be?" · BE activo":tt_in and tt_tp1hit?" · TP1 hit":""
    hud.f_row(81,"TRADE",      tt_result+(tt_in?" · "+str.tostring(bar_index-tt_bar)+"b · "+str.tostring(tt_pnl,"#.##")+"R"+_be_tag:tt_total>0?" · "+str.tostring(tt_pnl,"#.##")+"R":""), tt_result_color)
    hud.f_row(82,"STATS",      str.tostring(tt_wins)+"W/"+str.tostring(tt_losses)+"L  WR:"+str.tostring(math.round(tt_wr*100))+"%  E:"+(tt_expectancy>=0?"+":"")+str.tostring(tt_expectancy,"#.##")+"R  PF:"+str.tostring(tt_pf,"#.##"), tt_pnl_total>=0?col_long:col_short)
    hud.f_row(83,"P&L",        (tt_pnl_disp>=0?"+":"")+str.tostring(tt_pnl_disp,"#.##")+"R  MaxDD:"+str.tostring(tt_max_dd,"#.##")+"R", tt_pnl_disp>=0?col_long:col_short)
    hud.f_row(84,"CALMAR",     str.tostring(tt_calmar,"#.##")+"  Grade "+tt_live_grade+(tt_total<5?" (n="+str.tostring(tt_total)+")":""), tt_calmar_color)
    hud.f_row(85,"STREAK",     streak_txt, streak_color)
    hud.f_row(86,"DAILY R",    daily_r_txt, daily_r_color)


    hud.f_hdr(96,"── AUTO-BLOCK ──",auto_blocked?col_short:col_long)
    hud.f_row(97,"ROLLING",    str.tostring(rolling_active_n)+"/"+str.tostring(auto_block_window)+" tr  WR:"+str.tostring(math.round(rolling_wr*100))+"%  PF:"+str.tostring(rolling_pf,"#.##")+(auto_blocked?" · BLOQUEADO":" · OK"), auto_blocked?col_short:col_long)
    hud.f_row(98,"COOLDOWN",   in_cooldown?"EN COOLDOWN "+str.tostring(hard_cooldown_bars-(bar_index-last_loss_bar))+"b":consec_losses>0?"Activo · "+str.tostring(consec_losses)+"L":"OK", in_cooldown?col_warn:col_long)

// B11 — PLOTS EN CHART
_cup=regime_trend_up?col_long:regime_trend_down?color.new(col_long,50):regime_volatile?col_warn:color.new(color.yellow,30)
_cdn=regime_trend_down?col_short:regime_trend_up?color.new(col_short,50):regime_volatile?col_warn:color.new(color.yellow,30)
plotcandle(open,high,low,close,color=close>=open?_cup:_cdn,wickcolor=close>=open?_cup:_cdn,bordercolor=close>=open?_cup:_cdn,title="Regime Candles")

// ENTRY CANDLE HIGHLIGHT — barcolor() NO cuenta como plot, tinta la vela cuando hay señal
_is_entry_l = show_signals and (exec_long_v  or elite_long_ict  or elite_long)
_is_entry_s = show_signals and (exec_short_v or elite_short_ict or elite_short)
_is_entry   = _is_entry_l or _is_entry_s
_entry_body = elite_long_ict or elite_short_ict ? col_elite : elite_long ? color.lime : elite_short ? color.red : exec_long_v ? color.aqua : exec_short_v ? color.fuchsia : na
barcolor(_is_entry?_entry_body:na, title="ENTRY · Elite=cyan, Long=lime/aqua, Short=red/fuchsia")
plot(show_ema50 ?ema50 :na,"EMA 50", color=color.new(color.orange,40),linewidth=2)
plot(show_ema200?ema200:na,"EMA 200",color=color.new(color.fuchsia,30),linewidth=2)
plot(show_avwap ?avwap :na,"AVWAP",  color=color.new(color.yellow,25),linewidth=2,style=plot.style_circles)

_hypo=show_levels and not tt_in
plot(_hypo?sl_display :na,"SL",  color=sl_is_hyp?color.new(col_short,55):col_short,style=plot.style_linebr,linewidth=2)
plot(_hypo?tp1_display:na,"TP1", color=tp_is_hyp?color.new(col_long,55):col_long,  style=plot.style_linebr,linewidth=2)


_act=show_levels and tt_in
plot(_act and not tt_be?tt_sl   :na,"SL trade", color=col_short,              style=plot.style_linebr,linewidth=3)
plot(_act           ?tt_tp1     :na,"TP1 trade",color=col_long,               style=plot.style_linebr,linewidth=3)
plot(_act           ?tt_entry   :na,"ENTRY",    color=color.yellow,            style=plot.style_linebr,linewidth=2)
plot(_act and tt_be ?tt_entry   :na,"BE activo",color=color.new(color.aqua,0),style=plot.style_linebr,linewidth=4)
plot(show_swings?swing_h:na,"Swing H",color=color.new(col_short,30),style=plot.style_circles,linewidth=2,display=display.pane)
plot(show_swings?swing_l:na,"Swing L",color=color.new(col_long,30), style=plot.style_circles,linewidth=2,display=display.pane)

_sel=show_levels and show_quality_levels and _q_elite_long
_ses=show_levels and show_quality_levels and _q_elite_short
_sxl=show_levels and show_quality_levels and _q_exec_long  and not _q_elite_long
_sxs=show_levels and show_quality_levels and _q_exec_short and not _q_elite_short
_swl=show_levels and show_quality_levels and _q_watch_long and not _q_elite_long and not _q_exec_long
_sws=show_levels and show_quality_levels and _q_watch_short and not _q_elite_short and not _q_exec_short
_ea=tt_in?50:0
_xa=tt_in?55:20
_wa=tt_in?65:35
plot(_sel?_ph_sl_el:_ses?_ph_sl_es:na,"ELITE SL", color=color.new(color.red,   _ea),style=plot.style_linebr,linewidth=3,display=display.pane)
plot(_sel?_ph_tp_el:_ses?_ph_tp_es:na,"ELITE TP", color=color.new(color.green, _ea),style=plot.style_linebr,linewidth=3,display=display.pane)
plot(_sxl?_ph_sl_xl:_sxs?_ph_sl_xs:na,"EXEC SL",  color=color.new(#9370DB,    _xa),style=plot.style_linebr,linewidth=3,display=display.pane)
plot(_sxl?_ph_tp_xl:_sxs?_ph_tp_xs:na,"EXEC TP",  color=color.new(color.orange,_xa),style=plot.style_linebr,linewidth=3,display=display.pane)
plot(_swl?_ph_sl_wl:_sws?_ph_sl_ws:na,"WATCH SL", color=color.new(color.gray,80),style=plot.style_linebr,linewidth=1,display=display.pane)
plot(_swl?_ph_tp_wl:_sws?_ph_tp_ws:na,"WATCH TP", color=color.new(color.gray,80),style=plot.style_linebr,linewidth=1,display=display.pane)

// Niveles del modelo activo en chart
_brk_show = show_levels and (strat_name=="breakout" or strat_name=="breakdown")
plot(_brk_show?_m_hi[1]:na,"BRK nivel",  color=color.new(col_elite,30),style=plot.style_stepline,linewidth=1)
plot(_brk_show?_m_lo[1]:na,"BDN nivel",  color=color.new(col_warn, 30),style=plot.style_stepline,linewidth=1)
_tma_show = show_levels and strat_name=="tma_bands"
plot(_tma_show?m_tma_upper:na,"TMA Up", color=color.new(col_long, 40),style=plot.style_linebr,linewidth=1)
plot(_tma_show?m_tma_lower:na,"TMA Lo", color=color.new(col_short,40),style=plot.style_linebr,linewidth=1)

// VWAP diario y rango del día
plot(d_vwap,"VWAP D",  color=color.new(color.aqua,20),linewidth=2,style=plot.style_linebr)
plot(d_h,   "Day H",   color=color.new(color.silver,50),linewidth=1,style=plot.style_stepline,display=display.pane)
plot(d_l,   "Day L",   color=color.new(color.silver,50),linewidth=1,style=plot.style_stepline,display=display.pane)

// 4H EMA 50 en chart
plot(show_ema50?ema50_4h:na,"EMA50 4H",color=color.new(color.orange,65),linewidth=1,style=plot.style_linebr)

// Background RSI-W regime (muy suave)
bgcolor(m_vps_bull?color.new(color.green,97):m_vps_bear?color.new(color.red,97):na)

_sgl=exec_long_v  or elite_long_ict or elite_long
_sgs=exec_short_v or elite_short_ict or elite_short
_slc=elite_long_ict?col_elite:exec_long_v?color.aqua:col_long
_ssc=elite_short_ict?col_elite:exec_short_v?color.aqua:col_short
plotshape(show_signals and _sgl,text="L",style=shape.triangleup,  location=location.belowbar,color=_slc,textcolor=color.white,size=size.large)
plotshape(show_signals and _sgs,text="S",style=shape.triangledown,location=location.abovebar,color=_ssc,textcolor=color.white,size=size.large)

// ENTRY LABEL — big visible label with direction + signal grade + RR
if barstate.isconfirmed and show_signals and (_sgl or _sgs)
    _e_grade   = elite_long_ict or elite_short_ict ? "ELITE+ ICT" : elite_long or elite_short ? "ELITE" : "EXEC"
    _e_dir     = _sgl ? "▲ LONG" : "▼ SHORT"
    _e_rr      = rr_display > 0 ? "  RR 1:" + str.tostring(rr_display, "#.#") : ""
    _e_txt     = _e_dir + " · " + _e_grade + "\n" + strat_name + _e_rr
    _e_col     = _sgl ? _slc : _ssc
    _e_y       = _sgl ? low  : high
    _e_style   = _sgl ? label.style_label_up : label.style_label_down
    label.new(bar_index, _e_y, _e_txt, color=_e_col, textcolor=color.white, style=_e_style, size=size.normal, yloc=yloc.price, textalign=text.align_left)
plotshape(show_signals and reversal_signal,text="REV",  style=shape.diamond, location=location.abovebar,color=color.purple,textcolor=color.white,size=size.tiny)
plotshape(show_signals and choch_first,    text="CHoCH",style=shape.labelup, location=location.belowbar,color=color.purple,textcolor=color.white,size=size.tiny)
plotshape(show_signals and fake_move,      text="TRAP", style=shape.xcross,  location=location.abovebar,color=col_warn,    textcolor=color.white,size=size.tiny)
plotshape(show_signals and gap_block,      text="GAP",  style=shape.flag,    location=location.belowbar,color=col_warn,    textcolor=color.white,size=size.tiny)
plotshape(show_signals and auto_blocked and not auto_blocked[1],text="BLK",style=shape.flag,location=location.abovebar,color=col_short,textcolor=color.white,size=size.small)

bgcolor(in_session_a?color.new(col_long,93):in_session_b?color.new(col_elite,93):na)
bgcolor(_sgl and not _sgs?(elite_long_ict?color.new(col_elite,40):elite_long?color.new(color.lime,55):color.new(col_long,65)):na)
bgcolor(_sgs and not _sgl?(elite_short_ict?color.new(col_elite,40):elite_short?color.new(color.red,55):color.new(col_short,65)):na)
bgcolor(auto_blocked?color.new(col_short,94):gap_block?color.new(col_warn,90):na)

// B12 — ALERTAS
var int al_sig=-10000
var int al_rv=-10000
var int al_xr=-10000
var int al_dd=-10000
var int al_cf=-10000
var int al_blk=-10000
f_can(lb)=>bar_index-lb>=alert_cooldown
_b='"chat_id":"'+tg_chat_id+'","text":"'

// Contexto rico para alertas (calculado cada barra)
_al_ico  = smart_long?"🟢 LONG":"🔴 SHORT"
_al_ict  = (elite_long_ict or elite_short_ict)?" ✦ICT":""
_al_sl   = not na(sl_price)?str.tostring(sl_price,format.mintick)+"(-"+str.tostring(sl_dist_pct,"#.##")+"%)":"~"
_al_tp   = not na(tp_price)?str.tostring(tp_price,format.mintick)+"(+"+str.tostring(tp_dist_pct,"#.##")+"%)":"~"
_al_r4st = rsi_4h>70?"SC":rsi_4h<30?"SV":rsi_4h>55?"▲":rsi_4h<45?"▼":"—"
_al_vd   = math.round(d_vol_vs7d)
_al_vs   = _al_vd>150?"!":_al_vd>120?"↑":_al_vd<70?"↓":""
_al_ctx  = (_al_ico+_al_ict+" · "+strat_name+"\n"
            +syminfo.ticker+" "+tf_label+" @ "+str.tostring(close,format.mintick)+"\n"
            +"SL:"+_al_sl+" TP:"+_al_tp+"\n"
            +"RSI-W:"+str.tostring(rsi_w,"#.#")+" "+_reg_txt+"("+str.tostring(m_rsi_w_b)+")"
            +"  4H:"+str.tostring(rsi_4h,"#.#")+_al_r4st+"\n"
            +"VelaD:"+str.tostring(math.round(d_pos_pct))+"%"
            +"  Vol:"+str.tostring(_al_vd)+"%"+_al_vs
            +"  ↑"+str.tostring(d_dist_hi,"#.##")+"%\n"
            +"OFI:"+ofi_txt+"  Conf:"+str.tostring(math.round(confluencia)))

// Alerta única de señal con contexto completo
if m_has_signal and barstate.isconfirmed and f_can(al_sig)
    al_sig:=bar_index
    alert('{'+_b+_al_ctx+'"}',alert.freq_once_per_bar_close)
if reversal_signal and barstate.isconfirmed and f_can(al_rv)
    al_rv:=bar_index
    alert('{'+_b+'REVERSAL '+syminfo.ticker+'"}',alert.freq_once_per_bar_close)
if cross_risk_flag and barstate.isconfirmed and f_can(al_xr)
    al_xr:=bar_index
    alert('{'+_b+'CROSS RISK '+syminfo.ticker+'"}',alert.freq_once_per_bar_close)
if consec_losses>=dd_losses_l2 and barstate.isconfirmed and f_can(al_dd)
    al_dd:=bar_index
    alert('{'+_b+'DD ALTO '+str.tostring(consec_losses)+'L"}',alert.freq_once_per_bar_close)
if ta.crossover(confluencia,75) and barstate.isconfirmed and f_can(al_cf)
    al_cf:=bar_index
    alert('{'+_b+'CONFLUENCIA '+str.tostring(math.round(confluencia))+'"}',alert.freq_once_per_bar_close)
if auto_blocked and not auto_blocked[1] and barstate.isconfirmed and f_can(al_blk)
    al_blk:=bar_index
    alert('{'+_b+'AUTO-BLOCK WR:'+str.tostring(math.round(rolling_wr*100))+'%"}',alert.freq_once_per_bar_close)

// B13 — JSON EXPORT
_pad2(n)=>n<10?"0"+str.tostring(n):str.tostring(n)
_ts=str.tostring(year(time,"UTC"))+"-"+_pad2(month(time,"UTC"))+"-"+_pad2(dayofmonth(time,"UTC"))+"T"+_pad2(hour(time,"UTC"))+":"+_pad2(minute(time,"UTC"))+":00Z"
_jb(b)=>b?"true":"false"
_j2(f)=>str.tostring(f,"#.##")
_j4(f)=>str.tostring(f,"#.####")
_j6(f)=>str.tostring(f,"#.######")
_jp(f)=>na(f)?"null":str.tostring(f,"#.######")

_ja1 = '{"v":"13.0","ts":"'+_ts+'","sym":"'+syminfo.ticker+'","tf":"'+tf_label+'","asset":"'+asset_type_txt+'",'
_ja2 = '"price":'+_j6(close)+',"regime":"'+regime_txt+'","dual_mode":"'+dual_mode_txt+'","hurst":'+_j2(hurst)+',"adx":'+_j2(adx14)+',"slope":'+_j4(price_slope_norm)+','
